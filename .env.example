# Safe to expose in the browser. Use the Supabase project URL and publishable key.
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional override. By default the forms use PUBLIC_SUPABASE_URL/functions/v1/submit-enquiry.
PUBLIC_FORM_ENDPOINT=

# Configure these as Supabase Edge Function secrets, never as PUBLIC_ variables.
# SUPABASE_SECRET_KEY=sb_secret_...
# RATE_LIMIT_SALT=generate-a-long-random-value
# ALLOWED_ORIGINS=https://cnvrtdigital.co.uk,http://127.0.0.1:4321
