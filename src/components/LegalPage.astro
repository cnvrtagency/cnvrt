---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import '@/styles/foundation-pages.css';

interface Props {
  title: string;
  description: string;
  updated?: string;
}

const { title, description, updated = '17 July 2026' } = Astro.props;
---

<BaseLayout title={`${title} | CNVRT`} description={description} robots="noindex, follow">
  <SiteHeader />
  <main id="main" class="legal-page">
    <div class="shell legal-page__layout">
      <div>
        <span class="menu-label">CNVRT / Last updated {updated}</span>
        <h1>{title}</h1>
      </div>
      <div class="legal-page__copy">
        <slot />
      </div>
    </div>
  </main>
  <SiteFooter />
</BaseLayout>
