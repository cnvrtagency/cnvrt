---
interface Props {
  name: 'meta' | 'google' | 'email' | 'seo' | 'aeo' | 'tools';
}

const { name } = Astro.props;
---

<svg class="service-icon" viewBox="0 0 48 48" aria-hidden="true">
  {name === 'meta' && (
    <>
      <circle cx="18" cy="24" r="10" />
      <circle cx="30" cy="24" r="10" />
      <path d="M12 31c6-15 12-15 24 0" />
    </>
  )}
  {name === 'google' && (
    <>
      <circle cx="21" cy="21" r="11" />
      <path d="m29 29 9 9M21 15v12M15 21h12" />
    </>
  )}
  {name === 'email' && (
    <>
      <rect x="8" y="11" width="32" height="22" rx="1" />
      <path d="m9 13 15 12 15-12M15 38h18" />
    </>
  )}
  {name === 'seo' && (
    <>
      <path d="M12 8h18l6 6v26H12zM30 8v7h6" />
      <path d="m17 32 5-6 5 3 5-8M31 21h3v3" />
    </>
  )}
  {name === 'aeo' && (
    <>
      <circle cx="13" cy="16" r="4" />
      <circle cx="35" cy="16" r="4" />
      <circle cx="24" cy="35" r="4" />
      <path d="m17 18 5 13m9-13-5 13M17 16h14" />
      <path d="M22 14c0-2 1-3 3-3s3 1 3 3c0 3-4 3-4 6M24 23h.01" />
    </>
  )}
  {name === 'tools' && (
    <>
      <rect x="8" y="8" width="13" height="13" rx="1" />
      <rect x="27" y="8" width="13" height="13" rx="1" />
      <rect x="8" y="27" width="13" height="13" rx="1" />
      <path d="M27 33.5h13M33.5 27v13M21 14.5h6M14.5 21v6" />
    </>
  )}
</svg>
