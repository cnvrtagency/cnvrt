---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import type { ArticleMeta } from '@/data/articles';
import '@/styles/article-page.css';

interface Props {
  article: ArticleMeta;
}

const { article } = Astro.props;
const articleUrl = new URL(`/blog/${article.slug}/`, Astro.site).href;
const blogUrl = new URL('/blog/', Astro.site).href;
const authorUrl = new URL('/about/', Astro.site).href;
const imageUrl = new URL(article.image.src, Astro.site).href;
const schema = [
  {
    '@type': 'BlogPosting',
    '@id': `${articleUrl}#article`,
    mainEntityOfPage: { '@id': `${articleUrl}#webpage` },
    headline: article.title,
    description: article.description,
    image: [imageUrl],
    datePublished: article.published,
    dateModified: article.modified,
    author: {
      '@type': 'Person',
      '@id': `${authorUrl}#daniel-lyons`,
      name: article.author,
      jobTitle: article.authorRole,
      url: authorUrl,
    },
    publisher: { '@id': `${Astro.site}#organization` },
    isPartOf: { '@id': `${blogUrl}#blog` },
    inLanguage: 'en-GB',
  },
  {
    '@type': 'WebPage',
    '@id': `${articleUrl}#webpage`,
    url: articleUrl,
    name: article.title,
    description: article.description,
    isPartOf: { '@id': `${Astro.site}#website` },
    breadcrumb: { '@id': `${articleUrl}#breadcrumb` },
    primaryImageOfPage: { '@type': 'ImageObject', contentUrl: imageUrl },
    datePublished: article.published,
    dateModified: article.modified,
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${articleUrl}#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: blogUrl },
      { '@type': 'ListItem', position: 3, name: article.title, item: articleUrl },
    ],
  },
];
---

<BaseLayout
  title={`${article.title} | CNVRT`}
  description={article.description}
  additionalSchema={schema}
  ogType="article"
  socialImage={imageUrl}
  publishedTime={article.published}
  modifiedTime={article.modified}
>
  <SiteHeader />
  <main id="main" class="article-page">
    <header class:list={['article-hero', { 'article-hero--motion': article.video }]}>
      {article.video && (
        <div class="article-hero__media" aria-hidden="true">
          <Image src={article.image} alt="" widths={[960, 1440, 2200]} sizes="100vw" />
          <video class="article-hero__video" autoplay muted loop playsinline preload="auto" poster={article.image.src}>
            {article.videoWebm && <source src={article.videoWebm} type="video/webm" />}
            <source src={article.video} type="video/mp4" />
          </video>
        </div>
      )}
      <div class="shell">
        <nav class="article-breadcrumbs" aria-label="Breadcrumb" data-reveal>
          <a href="/">Home</a><span aria-hidden="true">/</span><a href="/blog/">Blog</a><span aria-hidden="true">/</span><span>{article.category}</span>
        </nav>
        <div class="article-hero__layout">
          <div class="article-hero__copy" data-reveal>
            <p class="article-kicker">{article.eyebrow}</p>
            <h1>{article.title}</h1>
            <p class="article-dek">{article.description}</p>
          </div>
          <div class="article-hero__side" data-reveal style="--reveal-index: 1">
            <p>{article.audience}</p>
            <dl class="article-meta">
              <div><dt>Written by</dt><dd><a href="/about/">{article.author}</a><span>{article.authorRole}</span></dd></div>
              <div><dt>Published</dt><dd><time datetime={article.published}>{article.publishedLabel}</time></dd></div>
              <div><dt>Last reviewed</dt><dd><time datetime={article.modified}>{article.modifiedLabel}</time></dd></div>
              <div><dt>Reading time</dt><dd>{article.readTime}</dd></div>
            </dl>
          </div>
        </div>
      </div>
    </header>

    {!article.video && (
      <figure class="article-lead-media shell" data-reveal="clip">
        <div class="article-lead-media__visual"><Image src={article.image} alt={article.imageAlt} widths={[720, 1100, 1600, 2200]} sizes="(max-width: 760px) 100vw, 88vw" /></div>
        <figcaption><span>Editorial field note</span><p>{article.imageCaption}</p></figcaption>
      </figure>
    )}

    <section class="article-answer" aria-labelledby="quick-answer-title">
      <div class="shell article-answer__layout">
        <p class="article-answer__label">The short answer</p>
        <div>
          <h2 id="quick-answer-title">What you need to know</h2>
          <p>{article.quickAnswer}</p>
        </div>
      </div>
    </section>

    <div class="shell article-layout">
      <aside class="article-contents" aria-label="Article contents">
        <div>
          <p>On this page</p>
          <ol>
            {article.toc.map((item, index) => <li><span>{String(index + 1).padStart(2, '0')}</span><a href={`#${item.id}`}>{item.label}</a></li>)}
          </ol>
        </div>
      </aside>

      <article class="article-body">
        <slot />
      </article>
    </div>

    <section class="article-next section-pad">
      <div class="shell">
        <div class="section-rail"><span>Next step</span><span>Apply the guidance</span><span>CNVRT</span></div>
        <div class="article-next__grid">
          <a href={article.primaryService.href}>
            <span>Relevant service</span>
            <h2>{article.primaryService.label}</h2>
            <p>{article.primaryService.description}</p>
            <b aria-hidden="true">↗</b>
          </a>
          <a href={article.caseStudy.href}>
            <span>Related evidence</span>
            <h2>{article.caseStudy.label}</h2>
            <p>{article.caseStudy.description}</p>
            <b aria-hidden="true">↗</b>
          </a>
        </div>
      </div>
    </section>

    <section class="article-closing section-pad">
      <div class="shell article-closing__layout">
        <div><span>Need a clearer starting point?</span><h2>Turn the guide into a practical review.</h2></div>
        <div><p>Share the current website, store or search problem. CNVRT will identify the most useful first checks and whether a wider project is justified.</p><div><a class="button button--paper" href="/request-an-audit/">Request an audit <span aria-hidden="true">↗</span></a><a class="text-link" href="/contact/">Contact CNVRT <span aria-hidden="true">↗</span></a></div></div>
      </div>
    </section>
  </main>

  <script>
    const articleHeroVideo = document.querySelector<HTMLVideoElement>('.article-hero__video');

    if (articleHeroVideo) {
      articleHeroVideo.muted = true;
      const tryArticleHeroPlayback = () => articleHeroVideo.play().catch(() => undefined);
      tryArticleHeroPlayback();
      document.addEventListener('pointerdown', tryArticleHeroPlayback, { once: true, passive: true });
      document.addEventListener('touchstart', tryArticleHeroPlayback, { once: true, passive: true });
    }

    document.querySelectorAll<HTMLTableElement>('.article-table').forEach((table) => {
      const labels = Array.from(table.querySelectorAll<HTMLTableCellElement>('thead th')).map((cell) => cell.textContent?.trim() ?? '');
      table.querySelectorAll<HTMLTableRowElement>('tbody tr').forEach((row) => {
        Array.from(row.cells).forEach((cell, index) => {
          cell.dataset.label = labels[index] ?? '';
        });
      });
    });
  </script>
  <SiteFooter />
</BaseLayout>
