---
interface Props {
  label: string;
  title: string;
  size: string;
  aspect?: 'landscape' | 'cinematic' | 'portrait' | 'square';
  tone?: 'grey' | 'warm' | 'dark' | 'violet';
  className?: string;
  revealIndex?: number;
  compact?: boolean;
}

const {
  label,
  title,
  size,
  aspect = 'landscape',
  tone = 'grey',
  className,
  revealIndex = 1,
  compact = false,
} = Astro.props;
---

<figure
  class:list={['editorial-image-placeholder', `editorial-image-placeholder--${aspect}`, `editorial-image-placeholder--${tone}`, { 'editorial-image-placeholder--compact': compact }, className]}
  role="img"
  aria-label={`${label}. ${title}. Placeholder image required at ${size}.`}
  data-reveal="clip"
  style={`--reveal-index: ${revealIndex}`}
>
  <span class="editorial-image-placeholder__label">{label}</span>
  <span class="editorial-image-placeholder__focus" aria-hidden="true"></span>
  <figcaption>
    <strong>{title}</strong>
    <small>{size}</small>
  </figcaption>
</figure>

<style>
  .editorial-image-placeholder {
    --placeholder-aspect: 8 / 5;
    position: relative;
    display: grid;
    min-width: 0;
    min-height: 0;
    aspect-ratio: var(--placeholder-aspect);
    grid-template-rows: auto 1fr auto;
    margin: 0;
    overflow: hidden;
    padding: clamp(1rem, 2vw, 1.5rem);
    border: 1px solid rgba(17,17,19,0.24);
    background: #cccac6;
    color: #46443f;
    isolation: isolate;
  }

  .editorial-image-placeholder::before,
  .editorial-image-placeholder::after {
    position: absolute;
    z-index: -1;
    inset: 0;
    content: '';
    pointer-events: none;
  }

  .editorial-image-placeholder::before {
    background:
      linear-gradient(to bottom right, transparent calc(50% - 0.5px), currentColor 50%, transparent calc(50% + 0.5px)),
      linear-gradient(to top right, transparent calc(50% - 0.5px), currentColor 50%, transparent calc(50% + 0.5px));
    opacity: 0.16;
  }

  .editorial-image-placeholder::after {
    margin: 0.7rem;
    border: 1px solid currentColor;
    opacity: 0.16;
  }

  .editorial-image-placeholder--cinematic { --placeholder-aspect: 16 / 7; }
  .editorial-image-placeholder--portrait { --placeholder-aspect: 4 / 5; }
  .editorial-image-placeholder--square { --placeholder-aspect: 1; }
  .editorial-image-placeholder--warm { background: #d6cec3; color: #4e4841; }
  .editorial-image-placeholder--violet { background: #c8bedc; color: #42384f; }
  .editorial-image-placeholder--dark { border-color: rgba(247,245,240,0.24); background: #29272d; color: rgba(247,245,240,0.84); }

  .editorial-image-placeholder__label,
  .editorial-image-placeholder figcaption {
    position: relative;
    z-index: 1;
  }

  .editorial-image-placeholder__label {
    font-size: 0.6rem;
    font-weight: 650;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .editorial-image-placeholder__focus {
    position: absolute;
    z-index: -1;
    top: 50%;
    left: 50%;
    width: min(30%, 8rem);
    aspect-ratio: 1;
    border: 1px solid currentColor;
    border-radius: 50%;
    opacity: 0.18;
    transform: translate(-50%, -50%);
  }

  .editorial-image-placeholder__focus::before,
  .editorial-image-placeholder__focus::after {
    position: absolute;
    top: 50%;
    left: 50%;
    background: currentColor;
    content: '';
    opacity: 0.7;
    transform: translate(-50%, -50%);
  }

  .editorial-image-placeholder__focus::before { width: 150%; height: 1px; }
  .editorial-image-placeholder__focus::after { width: 1px; height: 150%; }

  .editorial-image-placeholder figcaption {
    display: grid;
    align-self: end;
    gap: 0.5rem;
  }

  .editorial-image-placeholder strong {
    display: block;
    max-width: 24rem;
    overflow-wrap: anywhere;
    font-size: clamp(1.3rem, 3vw, 2.3rem);
    font-weight: 520;
    letter-spacing: -0.045em;
    line-height: 0.98;
  }

  .editorial-image-placeholder small {
    display: block;
    overflow-wrap: anywhere;
    font-size: 0.6rem;
    font-weight: 650;
    letter-spacing: 0.09em;
    opacity: 0.7;
    text-transform: uppercase;
  }

  .editorial-image-placeholder--compact strong { font-size: clamp(1.15rem, 2vw, 1.55rem); }

  @media (max-width: 47.999rem) {
    .editorial-image-placeholder--cinematic { --placeholder-aspect: 8 / 5; }
  }
</style>
