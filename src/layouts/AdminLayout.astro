---
import '@/styles/admin.css';

interface Props {
  title: string;
  description: string;
  skipLabel?: string;
  showMobileNav?: boolean;
}

const { title, description, skipLabel = 'Skip to workspace', showMobileNav = true } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <meta name="theme-color" content="#111113" />
    <link rel="preload" href="/fonts/general-sans-variable.woff2" as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
  </head>
  <body class="admin-body">
    <a class="admin-skip" href="#admin-main">{skipLabel}</a>
    <slot />
    {showMobileNav && (
      <>
        <nav class="admin-mobile-nav" aria-label="Mobile admin navigation">
          <a href="/admin/" data-admin-mobile-link="dashboard"><i aria-hidden="true"></i><span>Dashboard</span></a>
          <a href="/admin/#inbox-title" data-admin-mobile-link="enquiries"><i aria-hidden="true"></i><span>Enquiries</span></a>
          <a href="/admin/clients/" data-admin-mobile-link="clients"><i aria-hidden="true"></i><span>Clients</span></a>
          <a href="/admin/finance/" data-admin-mobile-link="finance"><i aria-hidden="true"></i><span>Finance</span></a>
          <a href="/admin/documents/" data-admin-mobile-link="documents"><i aria-hidden="true"></i><span>Docs</span></a>
        </nav>
        <script is:inline>
          (() => {
            const markActive = () => {
              const path = window.location.pathname;
              const active = path.startsWith('/admin/clients') ? 'clients' : path.startsWith('/admin/finance') ? 'finance' : path.startsWith('/admin/documents') ? 'documents' : window.location.hash === '#inbox-title' ? 'enquiries' : 'dashboard';
              document.querySelectorAll('[data-admin-mobile-link]').forEach((link) => link.removeAttribute('aria-current'));
              document.querySelector(`[data-admin-mobile-link="${active}"]`)?.setAttribute('aria-current', 'page');
            };
            markActive();
            window.addEventListener('hashchange', markActive);
          })();
        </script>
      </>
    )}
  </body>
</html>
