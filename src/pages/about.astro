---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import FoundationHero from '@/components/FoundationHero.astro';
import EditorialHeading from '@/components/EditorialHeading.astro';
import EditorialImagePlaceholder from '@/components/EditorialImagePlaceholder.astro';
import '@/styles/foundation-pages.css';

const principles = [
  ['01', 'Commercial context first', 'The work begins with the business model, customer, evidence and outcome. Channels only matter when they help move that outcome.'],
  ['02', 'Direct involvement', 'CNVRT stays close to the decisions and delivery, reducing the slow handovers and diluted thinking common in larger agency processes.'],
  ['03', 'Honest prioritisation', 'Not every business needs every service. Work is ordered around the strongest constraint and the most useful next investment.'],
  ['04', 'Built to keep improving', 'Websites, campaigns and systems launch with measurement, clear ownership and a practical view of what should happen next.'],
];

const pageUrl = new URL('/about/', Astro.site).href;
const schema = [
  {
    '@type': 'AboutPage',
    '@id': `${pageUrl}#about`,
    url: pageUrl,
    name: 'About CNVRT and Daniel Lyons',
    isPartOf: { '@id': `${Astro.site}#website` },
    about: { '@id': `${Astro.site}#organization` },
  },
  {
    '@type': 'Person',
    '@id': `${pageUrl}#daniel-lyons`,
    name: 'Daniel Lyons',
    jobTitle: 'Owner of CNVRT',
    worksFor: { '@id': `${Astro.site}#organization` },
    url: pageUrl,
  },
];
---

<BaseLayout title="About CNVRT and Daniel Lyons | Manchester" description="CNVRT is a Manchester digital agency owned by Daniel Lyons, connecting websites, ecommerce, acquisition, retention and useful business technology." additionalSchema={schema}>
  <SiteHeader />
  <main id="main" class="foundation-page">
    <FoundationHero eyebrow="About CNVRT" context="Manchester, UK" lines={['Close to the work.', 'Clear on the goal.', 'Built for growth.']} intro={[
      'CNVRT is a Manchester digital agency owned by Daniel Lyons, working with businesses that need considered digital work and more involvement from the person responsible for delivering it.',
      'Projects can begin with a website, Shopify store, campaign, search problem or custom tool, then expand only where another discipline creates clear commercial value.',
    ]}>
      <a class="button button--paper" href="/work/">See selected work <span aria-hidden="true">↗</span></a>
    </FoundationHero>

    <section class="section-pad">
      <div class="shell foundation-split">
        <div class="foundation-split__copy" data-reveal>
          <span>Why CNVRT</span>
          <EditorialHeading lines={['A smaller agency', 'with direct ownership', 'of the outcome.']} />
        </div>
        <div class="foundation-split__copy" data-reveal style="--reveal-index: 1">
          <p>Many businesses come to CNVRT after slow processes, fragmented suppliers or agency relationships where useful work stops when the allocated hours run out.</p>
          <p>CNVRT takes a more connected view. The website, acquisition channels, retention journey, tracking and operational systems are considered together, then effort is focused where it can create the most meaningful progress.</p>
          <p>The result is a direct working relationship with clearer decisions, visible delivery and fewer layers between the problem and the person solving it.</p>
        </div>
      </div>
    </section>

    <section class="about-image-section section-pad">
      <div class="shell">
        <div class="section-rail" data-reveal><span>02</span><span>People behind the work</span><span>Portrait + working context</span></div>
        <div class="foundation-media-pair">
          <EditorialImagePlaceholder label="Working image" title="Daniel reviewing strategy, design or live project work" size="1800 × 1200 px" aspect="landscape" tone="warm" revealIndex={1} />
          <EditorialImagePlaceholder label="Founder portrait" title="Daniel Lyons, owner of CNVRT" size="1200 × 1500 px" aspect="portrait" tone="violet" revealIndex={2} />
        </div>
      </div>
    </section>

    <section class="section-pad" style="background: var(--white)">
      <div class="shell">
        <div class="section-rail" data-reveal><span>03</span><span>Working principles</span><span>How decisions are made</span></div>
        <div class="foundation-card-grid" style="margin-top: 2.5rem">
          {principles.map(([number, title, copy], index) => <article class="foundation-card" data-reveal style={`--reveal-index: ${index}`}><div><span>{number}</span><h3>{title}</h3></div><p>{copy}</p></article>)}
        </div>
      </div>
    </section>

    <section class="foundation-cta section-pad">
      <div class="shell foundation-cta__layout">
        <div><span class="menu-label">Start a conversation</span><h2>Bring the goal, the problem or the early idea.</h2></div>
        <div><p>A complete brief is not required. CNVRT can help define the useful questions and the most credible place to begin.</p><div class="foundation-cta__actions"><a class="button button--paper" href="/contact/">Book a call <span aria-hidden="true">↗</span></a><a class="text-link" href="/submit-a-project/">Submit a project <span aria-hidden="true">↗</span></a></div></div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
