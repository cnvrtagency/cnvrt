const total = sections.reduce((sum, section) => sum + section.items.length, 0);
const completed = sections.reduce((sum, section) => sum + section.items.filter((item) => item.done).length, 0);
---

<BaseLayout title="CNVRT Project Checklist" description="Private working checklist for the CNVRT website project." robots="noindex, nofollow">
  <SiteHeader />
  <main id="main" class="checklist-page" data-checklist-root data-default-completed={completed} data-total={total}>
    <section class="checklist-hero">
      <div class="checklist-hero__grid" aria-hidden="true"></div>
      <div class="shell checklist-hero__layout">
        <div class="section-rail section-rail--inverse"><span>CNVRT</span><span>Project control</span><span>Local checklist</span></div>
        <div class="checklist-hero__copy">
          <div>
            <span class="menu-label">Website completion tracker</span>
            <h1>See what is done.<br /><span>Know what is next.</span></h1>
          </div>
          <p>Tick work off as it is approved. Progress is saved in this browser and organised by page, proof, content and launch readiness.</p>
        </div>
        <div class="checklist-summary" aria-live="polite">
          <div class="checklist-summary__figure"><strong data-progress-percent>{Math.round((completed / total) * 100)}%</strong><span>complete</span></div>
          <div class="checklist-summary__bar"><i data-progress-bar style={`--progress: ${(completed / total) * 100}%`}></i></div>
          <dl>
            <div><dt>Completed</dt><dd data-completed-count>{completed}</dd></div>
            <div><dt>Remaining</dt><dd data-remaining-count>{total - completed}</dd></div>
            <div><dt>Total</dt><dd>{total}</dd></div>
          </dl>
        </div>
      </div>
    </section>

    <section class="checklist-body section-pad">
      <div class="shell">
        <div class="checklist-toolbar">
          <div class="checklist-filters" role="group" aria-label="Filter checklist sections">
            <button type="button" class="is-active" data-filter="all">All</button>
            <button type="button" data-filter="active">In progress</button>
            <button type="button" data-filter="pending">Not started</button>
            <button type="button" data-filter="complete">Complete</button>
          </div>
          <button type="button" class="checklist-reset" data-reset-checklist>Reset saved ticks</button>
        </div>

        <div class="checklist-sections">
          {sections.map((section, index) => {
            const sectionDone = section.items.filter((item) => item.done).length;
            return (
              <details class="checklist-section" data-section data-kind={section.kind} open={index < 2}>
                <summary>
                  <span class="checklist-section__number">{section.number}</span>
                  <span class="checklist-section__heading"><strong>{section.title}</strong><small>{section.context}</small></span>
                  <span class="checklist-section__progress"><b data-section-count>{sectionDone}/{section.items.length}</b><i><em data-section-bar style={`--section-progress: ${(sectionDone / section.items.length) * 100}%`}></em></i></span>
                  <span class="checklist-section__toggle" aria-hidden="true"></span>
                </summary>
                <div class="checklist-items">
                  {section.items.map((item) => (
                    <label class="checklist-item">
                      <input type="checkbox" data-check-id={item.id} checked={item.done} />
                      <span class="checklist-item__box" aria-hidden="true"><svg viewBox="0 0 16 16"><path d="m3 8.5 3.1 3L13 4.8" /></svg></span>
                      <span class="checklist-item__copy"><strong>{item.label}</strong>{item.note && <small>{item.note}</small>}</span>
                    </label>
                  ))}
                </div>
              </details>
            );
          })}
        </div>
      </div>
    </section>
  </main>

  <script>
    const storageKey = 'cnvrt-project-checklist-v8';
    const previousStorageKey = 'cnvrt-project-checklist-v7';
    const root = document.querySelector<HTMLElement>('[data-checklist-root]');
    const checks = Array.from(document.querySelectorAll<HTMLInputElement>('[data-check-id]'));
    const sections = Array.from(document.querySelectorAll<HTMLDetailsElement>('[data-section]'));
    const filters = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter]'));
    const defaults = Object.fromEntries(checks.map((input) => [input.dataset.checkId!, input.defaultChecked]));

    const readSaved = () => {
      try {
        const current = localStorage.getItem(storageKey);
        if (current) return JSON.parse(current) as Record<string, boolean>;
        const previous = JSON.parse(localStorage.getItem(previousStorageKey) || '{}') as Record<string, boolean>;
        if (!Object.keys(previous).length) return {};
        const migrated: Record<string, boolean> = { ...previous, 'work-responsive': true, 'about-responsive': true };
        localStorage.setItem(storageKey, JSON.stringify(migrated));
        return migrated;
      }
      catch { return {}; }
    };

    const save = () => {
      const state = Object.fromEntries(checks.map((input) => [input.dataset.checkId!, input.checked]));
      localStorage.setItem(storageKey, JSON.stringify(state));
    };

    const sectionStatus = (section: HTMLDetailsElement) => {
      const sectionChecks = Array.from(section.querySelectorAll<HTMLInputElement>('[data-check-id]'));
      const done = sectionChecks.filter((input) => input.checked).length;
      if (done === sectionChecks.length) return 'complete';
      if (done === 0) return 'pending';
      return 'active';
    };

    const update = () => {
      const done = checks.filter((input) => input.checked).length;
      const percent = checks.length ? Math.round((done / checks.length) * 100) : 0;
      root?.querySelector<HTMLElement>('[data-progress-percent]')?.replaceChildren(`${percent}%`);
      root?.querySelector<HTMLElement>('[data-completed-count]')?.replaceChildren(String(done));
      root?.querySelector<HTMLElement>('[data-remaining-count]')?.replaceChildren(String(checks.length - done));
      root?.querySelector<HTMLElement>('[data-progress-bar]')?.style.setProperty('--progress', `${percent}%`);

      sections.forEach((section) => {
        const sectionChecks = Array.from(section.querySelectorAll<HTMLInputElement>('[data-check-id]'));
        const sectionDone = sectionChecks.filter((input) => input.checked).length;
        const sectionPercent = sectionChecks.length ? (sectionDone / sectionChecks.length) * 100 : 0;
        section.dataset.status = sectionStatus(section);
        section.querySelector<HTMLElement>('[data-section-count]')?.replaceChildren(`${sectionDone}/${sectionChecks.length}`);
        section.querySelector<HTMLElement>('[data-section-bar]')?.style.setProperty('--section-progress', `${sectionPercent}%`);
      });
    };

    const applyFilter = (filter: string) => {
      sections.forEach((section) => { section.hidden = filter !== 'all' && section.dataset.status !== filter; });
      filters.forEach((button) => button.classList.toggle('is-active', button.dataset.filter === filter));
    };

    const saved = readSaved();
    checks.forEach((input) => {
      const id = input.dataset.checkId!;
      if (Object.prototype.hasOwnProperty.call(saved, id)) input.checked = saved[id] ?? false;
      input.addEventListener('change', () => { save(); update(); });
    });

    filters.forEach((button) => button.addEventListener('click', () => applyFilter(button.dataset.filter || 'all')));
    document.querySelector<HTMLButtonElement>('[data-reset-checklist]')?.addEventListener('click', () => {
      if (!window.confirm('Reset every tick to the project defaults?')) return;
      checks.forEach((input) => { input.checked = defaults[input.dataset.checkId!] ?? false; });
      localStorage.removeItem(storageKey);
      localStorage.removeItem(previousStorageKey);
      update();
      applyFilter('all');
    });

    update();
  </script>
</BaseLayout>
