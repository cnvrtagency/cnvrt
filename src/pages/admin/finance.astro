---
import AdminLayout from '@/layouts/AdminLayout.astro';
import '@/styles/finance.css';
const configured = Boolean(import.meta.env.PUBLIC_SUPABASE_URL?.trim() && import.meta.env.PUBLIC_SUPABASE_ANON_KEY?.trim());
---

<AdminLayout title="Finance | CNVRT" description="Private CNVRT finance dashboard." skipLabel="Skip to finance dashboard">
  <div class="admin-root" data-finance-admin data-configured={String(configured)}>
    <section class="admin-login" data-auth-view aria-labelledby="finance-login-title">
      <div class="admin-login__brand"><img class="admin-logo" src="/brand/cnvrt-logo.png" alt="CNVRT" width="800" height="200" /><small>Private workspace / 03</small></div>
      <div class="admin-login__panel"><span class="admin-kicker">Finance administration</span><h1 id="finance-login-title">Know what is billed,<br />paid and outstanding.</h1><p>Sign in to review revenue, invoices, payments and client balances.</p><form class="admin-login__form" data-login-form><div class="admin-field"><label for="finance-email">Email address</label><input id="finance-email" name="email" type="email" autocomplete="username" required /></div><div class="admin-field"><label for="finance-password">Password</label><input id="finance-password" name="password" type="password" autocomplete="current-password" required /></div><p class="admin-form-status" data-login-status role="status" aria-live="polite"></p><button class="admin-button admin-button--primary" type="submit">Enter finance <span>↗</span></button></form></div>
      <div class="admin-login__foot"><span>Protected by Supabase Auth</span><span>GBP reporting</span></div>
    </section>

    <section class="admin-workspace" data-workspace hidden>
      <aside class="admin-sidebar" aria-label="Admin navigation"><a class="admin-wordmark" href="/admin/" aria-label="CNVRT admin home"><img class="admin-logo" src="/brand/cnvrt-logo.png" alt="" width="800" height="200" /></a><nav class="admin-sidebar__nav"><span>Workspace</span><a href="/admin/"><i></i>Dashboard</a><a href="/admin/#inbox-title"><i></i>Enquiries</a><a href="/admin/clients/"><i></i>Clients</a><a href="/admin/finance/" aria-current="page"><i></i>Finance</a><a href="/admin/documents/"><i></i>Documents</a></nav><div class="admin-sidebar__foot"><span><i></i>Protected workspace</span><small>CNVRT finance operations</small></div></aside>
      <div class="admin-shell"><header class="admin-header"><a class="admin-wordmark admin-wordmark--mobile" href="/admin/"><img class="admin-logo admin-logo--dark" src="/brand/cnvrt-logo.png" alt="CNVRT" width="800" height="200" /></a><div class="admin-header__context"><span>Finance</span><small data-sync-status>Connecting securely</small></div><button class="admin-text-button" type="button" data-sign-out>Sign out ↗</button></header>
        <main class="admin-main finance-admin" id="admin-main">
          <section class="admin-overview"><div><span class="admin-kicker">Commercial truth</span><h1>Finance overview</h1><p>Revenue, cash collection and client balances in one auditable GBP ledger.</p></div><div class="admin-overview__actions finance-period"><label for="finance-period"><span>Reporting period</span><select id="finance-period" data-finance-period><option value="this-month">This month</option><option value="last-month">Last month</option><option value="this-quarter">This quarter</option><option value="this-year">This year</option><option value="all">All time</option></select></label><button class="admin-button" type="button" data-refresh>Refresh data</button></div></section>
          <section class="finance-metrics" aria-label="Finance summary"><article><span>Invoices issued</span><strong data-finance-metric="invoiced">£0</strong><small data-finance-count="invoices">0 invoices</small></article><article><span>Cash received</span><strong data-finance-metric="payments">£0</strong><small data-finance-count="payments">0 payments</small></article><article data-tone="attention"><span>Outstanding</span><strong data-finance-metric="outstanding">£0</strong><small>Current client balances</small></article><article data-tone="credit"><span>Client credit</span><strong data-finance-metric="credits">£0</strong><small>Held on client accounts</small></article></section>
          <div class="finance-grid"><section class="admin-panel finance-chart" aria-labelledby="finance-chart-title"><div class="admin-panel__heading"><div><span class="admin-kicker">Cash movement</span><h2 id="finance-chart-title">Invoiced and paid by month</h2></div><p data-finance-period-label>This month</p></div><div class="finance-chart__legend"><span><i data-series="invoice"></i>Invoiced</span><span><i data-series="payment"></i>Paid</span></div><div class="finance-chart__plot" data-finance-chart></div></section><aside class="admin-panel finance-health" aria-labelledby="finance-health-title"><div class="admin-panel__heading"><div><span class="admin-kicker">Current account health</span><h2 id="finance-health-title">What needs attention</h2></div></div><div data-finance-health></div></aside></div>
          <section class="admin-panel finance-ledger" aria-labelledby="finance-ledger-title"><div class="admin-panel__heading"><div><span class="admin-kicker">Platform invoice register</span><h2 id="finance-ledger-title">Invoices, payments and clients</h2></div><p data-finance-summary>Loading finance records.</p></div><div class="finance-toolbar"><label><span>Search ledger</span><input type="search" placeholder="Client or invoice number" data-finance-search /></label><div class="finance-tabs" data-finance-tabs><button type="button" data-view="invoices" aria-pressed="true">Invoices</button><button type="button" data-view="payments" aria-pressed="false">Payments</button><button type="button" data-view="clients" aria-pressed="false">Clients</button></div><select aria-label="Filter invoice status" data-finance-status><option value="all">All invoice states</option><option value="invoiced">Invoiced</option><option value="paid">Paid</option><option value="overdue">Overdue</option><option value="draft">Draft</option></select></div><div class="finance-ledger__head" data-finance-head></div><div class="finance-ledger__body" data-finance-list aria-live="polite"></div></section>
        </main>
      </div>
    </section>
  </div>
  <script>import { initialiseFinanceAdmin } from '@/scripts/finance'; initialiseFinanceAdmin();</script>
</AdminLayout>
