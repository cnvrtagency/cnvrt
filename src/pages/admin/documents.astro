---
import AdminLayout from '@/layouts/AdminLayout.astro';
import '@/styles/documents.css';
const configured = Boolean(import.meta.env.PUBLIC_SUPABASE_URL?.trim() && import.meta.env.PUBLIC_SUPABASE_ANON_KEY?.trim());
---
<AdminLayout title="Documents | CNVRT" description="Private CNVRT document workspace." skipLabel="Skip to documents">
  <div class="admin-root" data-documents-admin data-configured={String(configured)}>
    <section class="admin-login" data-auth-view aria-labelledby="documents-login-title">
      <div class="admin-login__brand"><img class="admin-logo" src="/brand/cnvrt-logo.png" alt="CNVRT" width="800" height="200" /><small>Private workspace / 04</small></div>
      <div class="admin-login__panel"><span class="admin-kicker">Document administration</span><h1 id="documents-login-title">Templates in.<br />Client documents out.</h1><p>Sign in to manage reusable source files and assign finished versions to clients.</p><form class="admin-login__form" data-login-form><div class="admin-field"><label for="documents-email">Email address</label><input id="documents-email" name="email" type="email" autocomplete="username" required /></div><div class="admin-field"><label for="documents-password">Password</label><input id="documents-password" name="password" type="password" autocomplete="current-password" required /></div><p class="admin-form-status" data-login-status role="status"></p><button class="admin-button admin-button--primary" type="submit">Enter documents <span>↗</span></button></form></div>
    </section>
    <section class="admin-workspace" data-workspace hidden>
      <aside class="admin-sidebar" aria-label="Admin navigation"><a class="admin-wordmark" href="/admin/"><img class="admin-logo" src="/brand/cnvrt-logo.png" alt="CNVRT" width="800" height="200" /></a><nav class="admin-sidebar__nav"><span>Workspace</span><a href="/admin/"><i></i>Dashboard</a><a href="/admin/#inbox-title"><i></i>Enquiries</a><a href="/admin/clients/"><i></i>Clients</a><a href="/admin/finance/"><i></i>Finance</a><a href="/admin/documents/" aria-current="page"><i></i>Documents</a></nav><div class="admin-sidebar__foot"><span><i></i>Protected workspace</span><small>CNVRT document operations</small></div></aside>
      <div class="admin-shell"><header class="admin-header"><a class="admin-wordmark admin-wordmark--mobile" href="/admin/"><img class="admin-logo admin-logo--dark" src="/brand/cnvrt-logo.png" alt="CNVRT" width="800" height="200" /></a><div class="admin-header__context"><span>Documents</span><small data-sync-status>Connecting securely</small></div><button class="admin-text-button" type="button" data-sign-out>Sign out ↗</button></header>
        <main class="admin-main documents-admin" id="admin-main">
          <section class="admin-overview"><div><span class="admin-kicker">Templates and client files</span><h1>Document workspace</h1><p>Keep one approved source template, create a tailored version with Codex, then attach the finished file to the correct client.</p></div><div class="admin-overview__actions"><button class="admin-button" type="button" data-refresh>Refresh data</button></div></section>
          <section class="documents-flow" aria-label="Document workflow"><article><b>01</b><span><strong>Choose a template</strong><small>Use the approved source.</small></span></article><article><b>02</b><span><strong>Create with Codex</strong><small>Copy the brief and attach the DOCX.</small></span></article><article><b>03</b><span><strong>Assign the result</strong><small>Upload it against the client.</small></span></article></section>
          <div class="documents-grid"><section class="admin-panel"><div class="admin-panel__heading"><div><span class="admin-kicker">Source library</span><h2>Templates</h2></div><p>Controlled master files</p></div><div data-template-list class="document-list"></div></section>
          <section class="admin-panel document-create"><div class="admin-panel__heading"><div><span class="admin-kicker">New client version</span><h2>Assign a document</h2></div></div><form data-document-form><label><span>Template</span><select name="template_id" data-template-select required></select></label><label><span>Client</span><select name="client_id" data-client-select required><option value="">Choose client</option></select></label><label><span>Document title</span><input name="title" value="Website proposal" required /></label><label><span>Finished DOCX or PDF</span><input name="file" type="file" accept=".docx,.pdf" required /></label><div class="document-create__actions"><button class="admin-button" type="button" data-copy-brief>Copy Codex brief</button><button class="admin-button admin-button--primary" type="submit">Upload and assign ↗</button></div><p class="admin-form-status" data-document-status role="status"></p></form></section></div>
          <section class="admin-panel"><div class="admin-panel__heading"><div><span class="admin-kicker">Client library</span><h2>Assigned documents</h2></div><p data-document-summary>Loading documents.</p></div><div class="document-ledger" data-document-list></div></section>
        </main>
      </div>
    </section>
  </div>
  <script>import { initialiseDocumentsAdmin } from '@/scripts/documents'; initialiseDocumentsAdmin();</script>
</AdminLayout>
