---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import EditorialHeading from '@/components/EditorialHeading.astro';
import hearBetter from '@/assets/hear-better-home-test-landscape.png';
import hearBetterDesktop from '@/assets/hear-better-desktop-homepage.png';
import hearBetterMobile from '@/assets/hear-better-mobile-homepage-final.png';
import heatonsDesktop from '@/assets/heatons-desktop-homepage.png';
import heatonsMobile from '@/assets/heatons-mobile-homepage-reconstruction.png';
import uberKinky from '@/assets/uberkinky.jpg';
import topDraw from '@/assets/topdraw-prize-car-landscape.png';
import topDrawPortrait from '@/assets/topdraw-prize-car-portrait.png';
import homepageStructureArtwork from '@/assets/blog-homepage-structure-landscape.png';
import yaOmriShopify from '@/assets/ya-omri-shopify.jpg';
import routeProject from '@/assets/cnvrt-route-project.png';
import routeGrowth from '@/assets/cnvrt-route-growth.png';
import routeAudit from '@/assets/cnvrt-route-audit.png';
import journeyCommerceBackground from '@/assets/journey-commerce-background.png';
import journeyServiceBackground from '@/assets/journey-service-background.png';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL?.trim().replace(/\/$/, '') || '';
const formEndpoint = import.meta.env.PUBLIC_FORM_ENDPOINT?.trim() || (supabaseUrl ? `${supabaseUrl}/functions/v1/submit-enquiry` : '');

const projects = [
  { number: '01', name: 'Heatons Furniture', type: 'Shopify + connected growth', description: 'A complete rebrand, custom Shopify store and connected growth system that supported £480K in online sales during the first 12 months.', href: '/work/heatons-furniture/', image: heatonsDesktop, portraitImage: heatonsDesktop, mobileImage: heatonsMobile, alt: 'Heatons Furniture ecommerce website homepage' },
  { number: '02', name: 'TopDraw', type: 'Custom self-hosted platform', description: 'A competition business engineered from the ground up, connecting customer journeys, ecommerce, member accounts and administration.', href: '/work/topdraw/', image: topDraw, portraitImage: topDrawPortrait, alt: 'Representative blue sports car presented as a competition prize with a satin bow' },
  { number: '03', name: 'Hear Better', type: 'Brand + growth partnership', description: 'A complete brand, lead-generation website and acquisition system helping an independent audiology startup compete with national providers.', href: '/work/hear-better/', image: hearBetterDesktop, portraitImage: hearBetterDesktop, mobileImage: hearBetterMobile, alt: 'Hear Better website homepage' },
];

const clientLogos = [
  { name: 'Hear Better', src: '/logos/hear-better.png', width: 1007, height: 234 },
  { name: 'Heatons Furniture', src: '/logos/heatons-furniture.png', width: 400, height: 200 },
  { name: 'Ya Omri', src: '/logos/ya-omri.png', width: 400, height: 200 },
  { name: 'Hair Made Easi', src: '/logos/hair-made-easi.png', width: 429, height: 71 },
  { name: 'TopDraw', src: '/logos/topdraw.png', width: 429, height: 71 },
];

const services = [
  ['Web design', 'Distinctive, responsive websites shaped around the offer, customer journey and commercial action the business needs visitors to take.', '/services/web-design/', 'Build'],
  ['Branding', 'Brand positioning, visual identity and practical guidelines created to make the business recognisable across websites, ecommerce and marketing.', '/services/branding/', 'Identity'],
  ['Ecommerce web design', 'Ecommerce experiences built around product discovery, buying confidence, clear mobile journeys and stronger opportunities for repeat revenue.', '/services/ecommerce-web-design/', 'Commerce'],
  ['Shopify', 'Shopify stores designed and developed around daily trading, useful integrations, customer experience and the next stage of ecommerce growth.', '/services/shopify/', 'Commerce'],
  ['Shopify migrations', 'Controlled replatforming planned around catalogue data, redirects, integrations, testing and continuity before the new Shopify store goes live.', '/services/shopify-migrations/', 'Commerce'],
  ['SEO', 'Technical foundations, useful content and relevant authority developed to attract qualified organic demand and build visibility that compounds.', '/services/seo/', 'Search'],
  ['AEO', 'Clear expertise, evidence and online entities structured to improve how brands are understood across search engines and AI-led answers.', '/services/aeo/', 'AI search'],
  ['Google Ads', 'Paid search campaigns managed around customer intent, reliable measurement, qualified demand and commercially sensible use of budget.', '/services/google-ads/', 'Paid media'],
  ['Ecommerce PPC', 'Merchant Center, product feeds, Shopping and retail Performance Max managed around catalogue quality, transaction values and product economics.', '/services/ecommerce-ppc/', 'Retail media'],
  ['Meta Ads', 'Campaign strategy, creative testing and post-click journeys connected around useful measurement, qualified demand and sustainable returns.', '/services/meta-ads/', 'Paid media'],
  ['Email marketing', 'Campaigns, automated journeys and segmentation created to improve retention, repeat purchasing and the value of existing customer relationships.', '/services/email-marketing/', 'Retention'],
  ['Conversion optimisation', 'Customer journeys improved through analytics, customer evidence, UX review, responsive design and focused testing where the available traffic supports it.', '/services/conversion-rate-optimisation/', 'Improvement'],
  ['Analytics and tracking', 'GA4, Tag Manager, advertising signals, ecommerce events and customer outcomes connected around reliable commercial measurement and clearer decisions.', '/services/analytics-conversion-tracking/', 'Measurement'],
  ['Website support', 'Technical care, retained design and development, Shopify support and continuous improvement organised through one visible backlog.', '/services/website-support-maintenance/', 'Support'],
  ['Custom development', 'Custom functionality, integrations and web applications built around complex needs that standard platforms cannot serve efficiently.', '/services/custom-web-development/', 'Build'],
  ['Custom tools', 'Focused business software built to reduce repeated work, connect useful information and make complex operations easier to manage.', '/services/custom-tools/', 'Software'],
];

const process = [
  ['01', 'Understand', 'Clarify the audience, commercial goal, available evidence, constraints and current performance.'],
  ['02', 'Shape', 'Define the message, structure, priorities and visual direction before production begins.'],
  ['03', 'Build', 'Deliver responsively, review visibly and protect quality across every meaningful screen size.'],
  ['04', 'Improve', 'Launch with measurement in place, learn from performance and decide what should happen next.'],
];

const faqs = [
  ['What does CNVRT do?', 'CNVRT is a Manchester digital marketing agency providing branding, web design, ecommerce, SEO, AEO, paid media, ecommerce PPC, email marketing, conversion optimisation, analytics, website support and custom development. Services can be commissioned individually or connected around a wider commercial goal.'],
  ['What types of business does CNVRT work with?', 'CNVRT works with ecommerce brands, service businesses, local companies and funded startups. The important factors are a credible commercial opportunity, realistic investment and the ability to act on the work.'],
  ['Do I need a new website before starting marketing?', 'Not always. An existing website may support focused search, advertising or email work. If it is limiting performance, CNVRT will explain what needs to change, why it matters and whether improvement or replacement is more sensible.'],
  ['Can CNVRT manage several channels together?', 'Yes. Websites, search, paid media, email and measurement can be managed as one connected programme or introduced in stages around the most important opportunity.'],
  ['Does CNVRT work outside Manchester?', 'Yes. CNVRT is a Manchester digital marketing agency working with businesses across the UK and beyond through a clear remote process.'],
  ['What does an engagement cost?', 'Website projects start from £1,000. Ongoing marketing and growth engagements are scoped around the channels, workload, media spend and reporting requirements.'],
  ['Can I request an audit first?', 'Yes. CNVRT offers free, qualification-led audits where there is enough information to provide useful direction. Audits can cover websites, ecommerce, paid media, email, SEO or AEO.'],
];
---

<BaseLayout
  title="Digital Marketing Agency Manchester | CNVRT"
  description="CNVRT is a Manchester digital marketing agency connecting branding, web design, ecommerce, SEO, paid media, email and technology around business growth."
>
  <SiteHeader />

  <main id="main" class="home-motion">
    <section class="hero">
      <div class="hero-media" aria-hidden="true">
        <picture class="hero-media__poster">
          <source media="(max-aspect-ratio: 4/5)" srcset="/media/hero/cnvrt-hero-portrait-poster.webp" />
          <img src="/media/hero/cnvrt-hero-landscape-poster.webp" alt="" width="1920" height="1080" fetchpriority="high" />
        </picture>
        <video
          class="hero-media__video"
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          data-landscape-webm="/media/hero/cnvrt-hero-landscape.webm"
          data-landscape-mp4="/media/hero/cnvrt-hero-landscape.mp4"
          data-landscape-poster="/media/hero/cnvrt-hero-landscape-poster.webp"
          data-portrait-webm="/media/hero/cnvrt-hero-portrait.webm"
          data-portrait-mp4="/media/hero/cnvrt-hero-portrait.mp4"
          data-portrait-poster="/media/hero/cnvrt-hero-portrait-poster.webp"
        ></video>
      </div>
      <div class="shell hero__content">
        <div class="section-rail section-rail--hero" data-reveal style="--reveal-index: 0"><span>CNVRT / 2026</span><span>Manchester, UK</span><span>Design + marketing</span></div>

        <h1 class="hero-title" data-reveal="hero-title">
          <span class="hero-title__line"><span class="hero-title__inner">Manchester digital</span></span>
          <span class="hero-title__line"><span class="hero-title__inner">marketing agency.</span></span>
          <span class="hero-title__line"><span class="hero-title__inner">Built for growth.</span></span>
        </h1>

        <div class="hero-support" data-reveal style="--reveal-index: 4">
          <div class="hero-support__copy">
            <p>CNVRT connects websites, ecommerce, search, paid media, email and custom technology around the commercial problem limiting growth.</p>
            <p>Start with one focused project or bring the right channels together through an ongoing programme shaped around your business.</p>
          </div>
          <div class="hero-support__actions">
            <a class="button button--dark" href="#contact">Book a call <span aria-hidden="true">↗</span></a>
            <a class="text-link" href="/submit-a-project/">Submit a project <span aria-hidden="true">↗</span></a>
          </div>
        </div>
      </div>
    </section>

    <section class="client-marquee" aria-labelledby="client-marquee-title">
      <div class="client-marquee__layout">
        <div class="client-marquee__intro">
          <span>Selected clients</span>
          <h2 id="client-marquee-title"><span>Different sectors.</span><span>Shared ambition.</span></h2>
        </div>
        <div class="client-marquee__viewport">
          <div class="client-marquee__track">
            <ul class="client-marquee__group">
              {clientLogos.map((logo) => <li><img src={logo.src} alt={logo.name} width={logo.width} height={logo.height} loading="lazy" decoding="async" /></li>)}
            </ul>
            <ul class="client-marquee__group" aria-hidden="true">
              {clientLogos.map((logo) => <li><img src={logo.src} alt="" width={logo.width} height={logo.height} loading="lazy" decoding="async" /></li>)}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="work section-pad" id="work">
      <div class="shell">
        <div class="section-rail section-rail--inverse section-rail--borderless" data-reveal><span>01</span><span>Selected work</span><span>Three different briefs</span></div>
        <div class="section-intro section-intro--editorial" data-reveal style="--reveal-index: 1">
          <EditorialHeading lines={['Growth-focused work', 'built around the brief,', 'measured by growth.']} />
          <div>
            <p>Different businesses need different combinations of creative, technology and acquisition. Each engagement begins with the commercial problem, then shapes the right channels and customer journey around the outcome that matters.</p>
            <p>That can mean launching a new brand, moving an established retailer to Shopify or creating the technology behind a completely new customer experience.</p>
          </div>
        </div>
        <div class="project-grid">
          {projects.map((project) => (
            <article class="project" data-reveal>
              <a class="project__image" href={project.href} aria-label={`View ${project.name} case study`}>
                <span class="project-visual__desktop">
                  <span class="project-visual__browser" aria-hidden="true"><i></i><i></i><i></i></span>
                  <Image src={project.image} alt={project.alt} widths={[480, 760, 1000]} sizes="(max-width: 760px) 78vw, 26vw" />
                </span>
                <span class="project-visual__phone" aria-hidden="true">
                  <span class="project-visual__phone-bar"></span>
                  <Image src={project.mobileImage ?? project.portraitImage} alt="" widths={[180, 260, 360]} sizes="(max-width: 760px) 24vw, 8vw" />
                </span>
                <span class="project-visual__label" aria-hidden="true">Desktop / mobile</span>
                <span class="project__view" aria-hidden="true">View project ↗</span>
              </a>
              <div class="project__meta"><span>{project.number}</span><span>{project.type}</span></div>
              <h3><a href={project.href}>{project.name}</a></h3>
              <p>{project.description}</p>
              <a class="text-link" href={project.href}>View project <span aria-hidden="true">↗</span></a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="services-overview section-pad" id="services">
      <div class="shell">
        <div class="section-rail" data-reveal><span>02</span><span>Services</span><span>Build, acquire + retain</span></div>
        <div class="section-intro section-intro--editorial" data-reveal style="--reveal-index: 1">
          <EditorialHeading lines={['Connected expertise', 'around the problems', 'limiting growth.']} />
          <div><p>Websites, campaigns and customer journeys rarely perform in isolation. CNVRT connects the disciplines that influence discovery, conversion, retention and the ability to keep improving.</p><p>Begin with one clearly scoped service or combine the right areas through an ongoing growth programme. The work is shaped around need, not a fixed channel package.</p></div>
        </div>
        <div class="service-list-editorial">
          {services.map(([title, description, href, category], index) => (
            <a href={href} data-reveal style={`--reveal-index: ${index}`}>
              <span class="service-row__index">{String(index + 1).padStart(2, '0')}</span>
              <h3>{title}</h3>
              <p>{description}</p>
              <span class="service-row__action" aria-hidden="true"><span>{category}</span><b>↗</b></span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="working-together" id="project-guide" aria-labelledby="working-together-title">
      <div class="shell working-together__layout">
        <header class="working-together__header" data-reveal>
          <div>
            <span>How we work together</span>
            <h2 id="working-together-title">A clear place to begin.</h2>
            <p>Start with a defined project, an ongoing growth requirement or a focused audit. The right route depends on what the business needs now and how clearly the problem is already understood.</p>
          </div>
        </header>
        <div class="working-together__routes">
            <article class="working-together__route working-together__route--project" data-reveal>
              <figure><Image src={routeProject} alt="Architectural paper forms representing a focused digital project" widths={[480, 760, 1100]} sizes="(max-width: 760px) 92vw, 31vw" /></figure>
              <div class="working-together__route-copy">
              <span class="working-together__number">01</span>
              <h3>Focused project</h3>
              <div class="working-together__route-body">
                <p>For businesses with a defined requirement and a clear result in mind. CNVRT shapes the scope, priorities and delivery plan before production begins.</p>
                <p>Websites, Shopify stores, migrations and custom software are delivered around agreed outcomes, visible review points and practical launch requirements.</p>
              </div>
              <a class="working-together__action" href="/submit-a-project/">Submit a project <b aria-hidden="true">↗</b></a>
              </div>
            </article>
            <article class="working-together__route working-together__route--growth" data-reveal style="--reveal-index: 1">
              <figure><Image src={routeGrowth} alt="Chrome ribbon and glass forms representing connected ongoing growth" widths={[480, 760, 1100]} sizes="(max-width: 760px) 92vw, 31vw" /></figure>
              <div class="working-together__route-copy">
              <span class="working-together__number">02</span>
              <h3>Ongoing growth</h3>
              <div class="working-together__route-body">
                <p>For businesses that need consistent progress across connected channels. CNVRT identifies where focused attention will create the strongest commercial opportunity.</p>
                <p>Search, paid media, email and ongoing development are prioritised around demand, conversion, customer value and the evidence available from performance.</p>
              </div>
              <span class="working-together__meta">Scope tailored</span>
              <a class="working-together__action" href="#contact">Book a call <b aria-hidden="true">↗</b></a>
              </div>
            </article>
            <article class="working-together__route working-together__route--audit" data-reveal style="--reveal-index: 2">
              <figure><Image src={routeAudit} alt="Optical glass prism revealing a clear path through layered forms" widths={[480, 760, 1100]} sizes="(max-width: 760px) 92vw, 31vw" /></figure>
              <div class="working-together__route-copy">
              <span class="working-together__number">03</span>
              <h3>Audit and direction</h3>
              <div class="working-together__route-body">
                <p>For businesses that need clarity before making a larger commitment. CNVRT reviews the current position and identifies the problems limiting progress.</p>
                <p>Website, ecommerce or marketing performance is translated into useful evidence, clear priorities and a practical order for the work that follows.</p>
              </div>
              <span class="working-together__meta">Free, subject to fit</span>
              <a class="working-together__action" href="/request-an-audit/">Request an audit <b aria-hidden="true">↗</b></a>
              </div>
            </article>
        </div>
      </div>
    </section>

    <section class="visual-interlude" id="customer-journeys" aria-labelledby="customer-journeys-title">
      <div class="shell">
        <div class="section-rail" data-reveal><span>03</span><span>Customer journeys</span><span>Commerce + lead generation</span></div>
        <div class="visual-interlude__intro" data-reveal style="--reveal-index: 1">
          <EditorialHeading id="customer-journeys-title" lines={['Built around how', 'customers discover,', 'decide and return.']} />
          <p>Search, advertising, email and the website influence different moments in a decision. Connecting them creates a clearer experience for the customer and better information for the business.</p>
        </div>
        <div class="visual-interlude__stories">
          <article class="journey-story journey-story--commerce" data-reveal="clip">
            <div class="journey-story__stage">
              <Image class="journey-story__background" src={journeyCommerceBackground} alt="" widths={[720, 1100, 1536]} sizes="(max-width: 760px) 100vw, 68vw" />
              <figure class="journey-story__screen journey-story__screen--commerce">
                <Image src={heatonsDesktop} alt="Heatons Furniture ecommerce website" widths={[520, 820, 1200]} sizes="(max-width: 760px) 72vw, 46vw" />
              </figure>
              <figure class="journey-story__phone journey-story__phone--commerce">
                <Image src={heatonsMobile} alt="Heatons Furniture mobile ecommerce website" widths={[220, 360, 540]} sizes="(max-width: 760px) 28vw, 15vw" />
              </figure>
              <figure class="journey-story__tile journey-story__tile--commerce">
                <Image src={yaOmriShopify} alt="Luxury swimwear ecommerce campaign" widths={[320, 520, 760]} sizes="(max-width: 760px) 40vw, 20vw" />
              </figure>
              <div class="journey-story__signals" aria-label="Ecommerce customer journey"><span><b>01</b>Discover</span><span><b>02</b>Decide</span><span><b>03</b>Return</span></div>
              <span class="journey-story__marker" aria-hidden="true">Commerce / 01</span>
            </div>
            <div class="journey-story__caption"><span><b>01</b>Ecommerce</span><p>Product discovery, buying confidence and retention designed as one connected experience.</p></div>
          </article>
          <article class="journey-story journey-story--service" data-reveal="clip" style="--reveal-index: 2">
            <div class="journey-story__stage">
              <Image class="journey-story__background" src={journeyServiceBackground} alt="" widths={[620, 900, 1300]} sizes="(max-width: 760px) 100vw, 32vw" />
              <figure class="journey-story__screen journey-story__screen--service">
                <Image src={hearBetterDesktop} alt="Hear Better lead-generation website" widths={[420, 640, 900]} sizes="(max-width: 760px) 65vw, 24vw" />
              </figure>
              <figure class="journey-story__phone journey-story__phone--service">
                <Image src={hearBetterMobile} alt="Hear Better mobile website" widths={[220, 360, 540]} sizes="(max-width: 760px) 28vw, 11vw" />
              </figure>
              <figure class="journey-story__tile journey-story__tile--service">
                <Image src={hearBetter} alt="Hear Better mobile hearing assessment" widths={[320, 520, 760]} sizes="(max-width: 760px) 42vw, 16vw" />
              </figure>
              <div class="journey-story__signals" aria-label="Service customer journey"><span><b>01</b>Search</span><span><b>02</b>Trust</span><span><b>03</b>Enquire</span></div>
              <span class="journey-story__marker" aria-hidden="true">Lead generation / 02</span>
            </div>
            <div class="journey-story__caption"><span><b>02</b>Service</span><p>Useful information, visible proof and clear actions that turn attention into qualified enquiries.</p></div>
          </article>
        </div>
      </div>
    </section>

    <section class="approach section-pad" id="approach">
      <div class="shell">
        <div class="section-rail section-rail--inverse" data-reveal><span>04</span><span>Working approach</span><span>Four stages</span></div>
        <div class="section-intro section-intro--editorial" data-reveal style="--reveal-index: 1">
          <EditorialHeading lines={['Clear direction.', 'Focused delivery.', 'Useful measurement.']} />
          <p>A visible process keeps commercial priorities, creative decisions, technology and marketing moving in the same direction. Each stage produces a clear output and a useful point for review.</p>
        </div>
        <ol class="process-grid-editorial">
          {process.map(([number, title, description], index) => <li data-reveal style={`--reveal-index: ${index}`}><span>{number}</span><h3>{title}</h3><p>{description}</p></li>)}
        </ol>
        <aside class="audit-banner" id="audit" data-reveal><div><span>Not ready for a larger project?</span><EditorialHeading lines={['Find what is limiting', 'growth before adding', 'more activity.']} /><p>Request a focused website, Shopify, paid media, email, SEO or AEO audit. CNVRT will assess the current position, identify useful priorities and explain the most credible next step.</p></div><a class="button button--paper" href="/request-an-audit/">Request an audit <span aria-hidden="true">↗</span></a></aside>
      </div>
    </section>

    <section class="proof section-pad">
      <div class="shell">
        <div class="section-rail" data-reveal><span>05</span><span>Client perspective</span><span>Hear Better</span></div>
        <div class="proof-layout">
          <div class="proof-layout__image" data-reveal="clip"><Image src={hearBetter} alt="Representative Hear Better home hearing assessment" widths={[720, 1100, 1440]} sizes="(max-width: 760px) 100vw, 58vw" /><span>Mobile hearing care at home</span></div>
          <blockquote data-reveal style="--reveal-index: 2">
            <p>“CNVRT created the brand and website, helped me launch the business and now manage our SEO, AEO, paid advertising and ongoing growth.</p>
            <p>We are already appearing alongside much bigger national companies in local searches, bringing in a steady flow of enquiries and achieving a 10× return on ad spend through paid search.”</p>
            <footer><strong>Liam Hobson</strong><span>Founder, Hear Better</span></footer>
          </blockquote>
        </div>
      </div>
    </section>

    <section class="journal section-pad" id="blog">
      <div class="shell">
        <div class="section-rail" data-reveal><span>06</span><span>From the blog</span><a href="/blog/">View all articles ↗</a></div>
        <div class="section-intro section-intro--editorial" data-reveal style="--reveal-index: 1">
          <EditorialHeading lines={['Stronger thinking', 'for digital decisions', 'that drive growth.']} />
          <div>
            <p>Clear articles about making stronger digital decisions across web design, ecommerce, paid acquisition, email, SEO and AEO.</p>
            <p>Each guide is shaped around the questions businesses ask before and after investing in growth, turning research and practical experience into useful next steps.</p>
          </div>
        </div>
        <div class="article-grid">
          <article data-reveal style="--reveal-index: 0"><a class="article__image" href="/blog/homepage-structure-that-converts/"><Image src={homepageStructureArtwork} alt="Representative abstract digital architecture with a violet signal moving through connected structures" widths={[460, 720, 960]} sizes="(max-width: 760px) 100vw, 33vw" /></a><p class="article__meta">Web design + conversion / 15 min</p><h3><a href="/blog/homepage-structure-that-converts/">The homepage structure that actually converts</a></h3></article>
          <article data-reveal style="--reveal-index: 1"><a class="article__image" href="/blog/shopify-migration-checklist/"><Image src={uberKinky} alt="UberKinky Shopify Plus migration and ecommerce catalogue" widths={[460, 720, 960]} sizes="(max-width: 760px) 100vw, 33vw" /></a><p class="article__meta">Shopify + ecommerce / 18 min</p><h3><a href="/blog/shopify-migration-checklist/">What a safe Shopify migration needs to protect</a></h3></article>
          <article data-reveal style="--reveal-index: 2"><a class="article__image" href="/blog/seo-and-aeo-foundation/"><Image src={hearBetter} alt="Representative Hear Better mobile audiology service" widths={[460, 720, 960]} sizes="(max-width: 760px) 100vw, 33vw" /></a><p class="article__meta">SEO + AI search / 16 min</p><h3><a href="/blog/seo-and-aeo-foundation/">SEO and AEO need one strong foundation</a></h3></article>
        </div>
      </div>
    </section>

    <section class="closing section-pad">
      <div class="shell closing-layout">
        <div class="faq-block">
          <div class="section-rail section-rail--inverse" data-reveal><span>07</span><span>Useful details</span><span>Before we speak</span></div>
          <div data-reveal style="--reveal-index: 1"><EditorialHeading lines={['Clear answers for', 'choosing a partner', 'built around growth.']} /></div>
          <div class="faq-list" data-reveal style="--reveal-index: 2">{faqs.map(([question, answer]) => <details><summary>{question}<span aria-hidden="true">+</span></summary><p>{answer}</p></details>)}</div>
        </div>
        <aside class="contact-panel" id="contact" data-reveal>
          <span>Start a conversation</span>
          <EditorialHeading lines={['Where growth is stuck,', 'what needs to change,', 'and what comes next.']} />
          <p>Share the commercial goal, the current constraint and what meaningful progress would look like.</p>
          <form class="contact-form" name="homepage-enquiry" action="/thank-you/?form=homepage-enquiry" method="post" data-enquiry-form data-form-provider="supabase" data-form-name="homepage-enquiry" data-success-url="/thank-you/?form=homepage-enquiry" data-form-endpoint={formEndpoint || undefined}>
            <input type="hidden" name="form-name" value="homepage-enquiry" />
            <input type="hidden" name="enquiry-type" value="homepage" />
            <input type="hidden" name="source-page" value="/" />
            <input type="hidden" name="started-at" value="" />
            <input type="hidden" name="form-duration-ms" value="" />
            <p hidden><label>Leave this field empty <input name="company-website-confirmation" tabindex="-1" autocomplete="off" /></label></p>
            <div class="contact-form__progress">
              <div><span>Project outline</span><strong data-form-progress-text>0 of 4 complete</strong></div>
              <div class="contact-form__progress-track" role="progressbar" aria-label="Enquiry completion" aria-valuemin="0" aria-valuemax="4" aria-valuenow="0"><i></i></div>
            </div>
            <div class="contact-form__grid">
              <div class="form-field">
                <label for="contact-name"><span aria-hidden="true">01</span>Name<span class="form-field__check" aria-hidden="true">✓</span></label>
                <input id="contact-name" name="name" type="text" autocomplete="name" placeholder="Your name" required />
              </div>
              <div class="form-field">
                <label for="contact-email"><span aria-hidden="true">02</span>Work email<span class="form-field__check" aria-hidden="true">✓</span></label>
                <input id="contact-email" name="email" type="email" autocomplete="email" inputmode="email" placeholder="you@company.co.uk" required />
              </div>
              <div class="form-field">
                <label for="contact-company"><span aria-hidden="true">03</span>Company or website <em>Optional</em></label>
                <input id="contact-company" name="company" type="text" autocomplete="organization" placeholder="Company name or URL" />
              </div>
              <div class="form-field">
                <label for="contact-service"><span aria-hidden="true">04</span>Area of support<span class="form-field__check" aria-hidden="true">✓</span></label>
                <select id="contact-service" name="service" required>
                  <option value="" selected disabled>Select an area</option>
                  <option value="branding">Branding or brand identity</option>
                  <option value="web-design-ecommerce">Web design and ecommerce</option>
                  <option value="paid-media">Paid media</option>
                  <option value="ecommerce-ppc">Ecommerce PPC and Shopping</option>
                  <option value="email-marketing">Email marketing</option>
                  <option value="conversion-optimisation">Conversion optimisation</option>
                  <option value="analytics-tracking">Analytics and conversion tracking</option>
                  <option value="website-support">Website support and maintenance</option>
                  <option value="seo-aeo">SEO and AEO</option>
                  <option value="custom-tools">Custom Tools</option>
                  <option value="not-sure">Not sure yet</option>
                </select>
              </div>
              <div class="form-field form-field--wide">
                <label for="contact-brief"><span aria-hidden="true">05</span>What would you like to change?<span class="form-field__check" aria-hidden="true">✓</span></label>
                <textarea id="contact-brief" name="brief" rows="5" maxlength="600" placeholder="Tell us about the goal, the current constraint and what progress would look like." required></textarea>
                <div class="form-field__meta"><span>A few useful details are enough to begin.</span><span data-character-count>0 / 600</span></div>
              </div>
            </div>
            <div class="contact-form__footer">
              <div>
                <p>Your details will be used to assess and respond to this enquiry. Read the <a href="/privacy/">privacy policy</a>.</p>
                <a class="text-link" href="/contact/">Prefer to talk? Book a call <span aria-hidden="true">↗</span></a>
                <p class="contact-form__status" data-form-status role="status" aria-live="polite" hidden></p>
              </div>
              <button class="button button--paper" type="submit">Send enquiry <span aria-hidden="true">↗</span></button>
            </div>
          </form>
        </aside>
      </div>
    </section>
  </main>

  <script>
    const heroVideo = document.querySelector<HTMLVideoElement>('.hero-media__video');

    if (heroVideo) {
      const portraitMedia = window.matchMedia('(max-aspect-ratio: 4/5)');
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      let activeFormat = '';

      const configureHeroVideo = () => {
        const format = portraitMedia.matches ? 'portrait' : 'landscape';
        const poster = heroVideo.dataset[`${format}Poster`];
        if (poster) heroVideo.poster = poster;

        if (reducedMotion.matches) {
          heroVideo.pause();
          heroVideo.removeAttribute('src');
          heroVideo.load();
          heroVideo.classList.remove('is-ready');
          activeFormat = '';
          return;
        }

        if (activeFormat === format) return;
        const supportsWebm = heroVideo.canPlayType('video/webm; codecs="vp9"') !== '';
        const source = heroVideo.dataset[`${format}${supportsWebm ? 'Webm' : 'Mp4'}`];
        if (!source) return;

        heroVideo.classList.remove('is-ready');
        heroVideo.src = source;
        heroVideo.preload = 'metadata';
        heroVideo.load();
        heroVideo.play().catch(() => undefined);
        activeFormat = format;
      };

      const retryHeroPlayback = () => {
        if (!reducedMotion.matches) heroVideo.play().catch(() => undefined);
      };

      heroVideo.addEventListener('canplay', () => heroVideo.classList.add('is-ready'));
      document.addEventListener('pointerdown', retryHeroPlayback, { once: true, passive: true });
      document.addEventListener('touchstart', retryHeroPlayback, { once: true, passive: true });
      portraitMedia.addEventListener('change', configureHeroVideo);
      reducedMotion.addEventListener('change', configureHeroVideo);
      configureHeroVideo();
    }

    const clientMarquee = document.querySelector<HTMLElement>('.client-marquee');
    const marqueeReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    if (clientMarquee && !marqueeReducedMotion.matches && 'IntersectionObserver' in window) {
      const marqueeObserver = new IntersectionObserver(([entry]) => {
        if (!entry) return;
        clientMarquee.classList.toggle('is-running', entry.isIntersecting);
      }, { rootMargin: '10% 0px' });

      marqueeObserver.observe(clientMarquee);
    }

    const contactForm = document.querySelector<HTMLFormElement>('.contact-form');

    if (contactForm) {
      const requiredFields = Array.from(contactForm.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('[required]'));
      const allFields = Array.from(contactForm.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('input, select, textarea'));
      const progressText = contactForm.querySelector<HTMLElement>('[data-form-progress-text]');
      const progressBar = contactForm.querySelector<HTMLElement>('.contact-form__progress-track');
      const brief = contactForm.querySelector<HTMLTextAreaElement>('#contact-brief');
      const characterCount = contactForm.querySelector<HTMLElement>('[data-character-count]');

      const hasValue = (field: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement) => field.value.trim().length > 0;

      const updateFormState = () => {
        allFields.forEach((field) => field.closest('.form-field')?.classList.toggle('is-complete', hasValue(field) && field.validity.valid));
        const complete = requiredFields.filter((field) => hasValue(field) && field.validity.valid).length;
        contactForm.style.setProperty('--form-progress', String(complete / requiredFields.length));
        if (progressText) progressText.textContent = `${complete} of ${requiredFields.length} complete`;
        progressBar?.setAttribute('aria-valuenow', String(complete));
        if (brief && characterCount) characterCount.textContent = `${brief.value.length} / ${brief.maxLength}`;
      };

      contactForm.addEventListener('input', updateFormState);
      contactForm.addEventListener('change', updateFormState);
      updateFormState();
    }
  </script>

  <SiteFooter />
</BaseLayout>
