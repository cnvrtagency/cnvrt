---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import EditorialHeading from '@/components/EditorialHeading.astro';
import ResponsiveProjectImage from '@/components/ResponsiveProjectImage.astro';
import '@/styles/service-page.css';
import mobileFirst from '@/assets/mobile-first.png';
import hearBetter from '@/assets/hear-better-home-test-landscape.png';
import heatons from '@/assets/heatons-outcome-landscape.png';
import heatonsPortrait from '@/assets/heatons-outcome-portrait.png';
import uberKinky from '@/assets/uberkinky.jpg';
import hairMadeEasi from '@/assets/hair-made-easi.jpg';
import yaOmri from '@/assets/ya-omri-shopify.jpg';
import rftRecruitment from '@/assets/rft-recruitment-outcome-landscape.png';
import rftRecruitmentPortrait from '@/assets/rft-recruitment-outcome-portrait.png';
import topDraw from '@/assets/topdraw-prize-car-landscape.png';
import topDrawPortrait from '@/assets/topdraw-prize-car-portrait.png';

const heroReelPrimary = [hearBetter, heatons, hairMadeEasi];
const heroReelSecondary = [yaOmri, mobileFirst, heatons];

const outcomes = [
  ['01', 'Clarify the offer', 'Give the right visitor a faster understanding of what the business does, who it helps and why the offer matters.'],
  ['02', 'Build confidence', 'Use structure, content and visual detail to answer doubts and establish credibility before the first conversation.'],
  ['03', 'Guide the next step', 'Create deliberate journeys towards enquiries, purchases, bookings or the next useful piece of information.'],
  ['04', 'Support what follows', 'Prepare the site for measurement, search visibility, campaigns, retention and continued improvement after launch.'],
];

const capabilities = [
  ['01', 'Discovery and direction', 'Commercial goals, audiences, evidence, competitors and constraints translated into a clear project direction.'],
  ['02', 'Information architecture', 'Page hierarchy, navigation and journeys shaped around what visitors need to understand and do.'],
  ['03', 'UX and visual design', 'Responsive interfaces that balance clarity, character, accessibility and conversion intent.'],
  ['04', 'Responsive development', 'Production builds reviewed from mobile upward across modern browsers and meaningful screen sizes.'],
  ['05', 'Content and search foundations', 'Page purpose, heading structure, metadata, internal links and crawlable content considered before launch.'],
  ['06', 'Integrations and measurement', 'Forms, analytics, ecommerce, booking tools and practical functionality connected around the brief.'],
];

const platforms = [
  ['01', 'Service websites', 'Lead-generation and content-led websites for service businesses, local companies and growing organisations.', '/services/custom-web-development/'],
  ['02', 'Shopify and ecommerce', 'Product-led storefronts designed around discovery, purchase confidence and repeat customer value.', '/services/shopify/'],
  ['03', 'Custom builds', 'Purpose-built experiences and functionality when a standard platform cannot support the required workflow.', '/services/custom-web-development/'],
];

const process = [
  ['01', 'Understand', 'Define the audience, business goal, current constraints, evidence and measures of progress.'],
  ['02', 'Structure', 'Plan the sitemap, page priorities, content requirements and journeys before visual design begins.'],
  ['03', 'Design', 'Create a responsive visual system and review important screens at mobile and desktop sizes.'],
  ['04', 'Build and test', 'Develop the approved direction, connect required functionality and test the complete experience.'],
  ['05', 'Launch and learn', 'Protect the transition, confirm measurement and identify the most useful improvements after launch.'],
];

const work = [
  { number: '01', name: 'Hear Better', scope: 'Service website + PPC', description: 'A custom lead-generation website for a mobile audiology service, structured around trust, service clarity and booking intent.', href: '/work/hear-better/', image: hearBetter, alt: 'Hear Better website homepage', proof: ['Mobile service journey', 'Location-led discovery', 'Clear booking path'] },
  { number: '02', name: 'Ya Omri', scope: 'Custom Shopify redesign', description: 'A luxury ecommerce redesign combining editorial collection storytelling, custom product pages and responsive purchase journeys.', href: '/work/ya-omri/', image: yaOmri, alt: 'Ya Omri luxury swimwear Shopify website', proof: ['Custom Shopify theme', 'Product-page UX', 'Luxury visual direction'] },
  { number: '03', name: 'RFT Recruitment', scope: 'Brand + recruitment platform', description: 'A dual-audience lead-generation website connected to a custom CRM, CV database and sector categorisation system.', href: '/work/rft-recruitment/', image: rftRecruitment, portraitImage: rftRecruitmentPortrait, alt: 'Representative professional women greeting one another in a modern Manchester office', proof: ['Client and candidate journeys', 'Lead-generation forms', 'Custom CRM'] },
];

const previewWork = [
  ...work,
  { name: 'Heatons Furniture', scope: 'Shopify + connected growth', href: '/work/heatons-furniture/', image: heatons, portraitImage: heatonsPortrait, alt: 'Representative couple relaxing together on a comfortable corner sofa' },
  { name: 'UberKinky', scope: 'Shopline to Shopify Plus', href: '/work/uberkinky/', image: uberKinky, alt: 'UberKinky custom Shopify Plus storefront' },
  { name: 'TopDraw', scope: 'Custom self-hosted platform', href: '/work/topdraw/', image: topDraw, portraitImage: topDrawPortrait, alt: 'Representative blue sports car presented as a competition prize with a satin bow' },
];

const faqs = [
  ['How much does a website project cost?', 'CNVRT website projects start from £1,000. Final investment depends on the number and type of pages, content requirements, integrations, ecommerce needs and technical complexity. A clear scope and proposal are agreed before work begins.'],
  ['How long does a web design project take?', 'Timing depends on scope, feedback, content readiness and technical requirements. The proposal will set out the planned stages and dependencies rather than applying one fixed timeframe to every project.'],
  ['Will the website work properly on mobile?', 'Yes. Layouts are designed and reviewed from mobile upward, with important journeys tested across compact phones, tablets, laptops and wider screens.'],
  ['Is SEO included in the website build?', 'Technical and on-page foundations are considered during the build, including structure, crawlability, metadata, internal links and performance. Ongoing SEO strategy and content growth can be scoped separately where required.'],
  ['Which platform will my website use?', 'The platform follows the brief. Shopify is used for suitable ecommerce projects, while service websites and custom requirements are matched to the editing, integration, performance and ownership needs of the business.'],
  ['Can CNVRT improve an existing website instead?', 'Yes. An audit can identify whether focused UX, design, development or conversion improvements are more appropriate than a complete rebuild.'],
];

const pageUrl = new URL('/services/web-design/', Astro.site).href;
const schema = [
  {
    '@type': 'WebPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: 'Web Design Agency Manchester | CNVRT',
    description: 'Web design and development in Manchester for service businesses, ecommerce brands and organisations that need a clearer, higher-performing digital experience.',
    isPartOf: { '@id': `${Astro.site}#website` },
    about: { '@id': `${pageUrl}#service` },
    inLanguage: 'en-GB',
  },
  {
    '@type': 'Service',
    '@id': `${pageUrl}#service`,
    name: 'Web design and development',
    serviceType: 'Web design and development',
    url: pageUrl,
    provider: { '@id': `${Astro.site}#organization` },
    areaServed: { '@type': 'Country', name: 'United Kingdom' },
    audience: { '@type': 'BusinessAudience', audienceType: 'Service businesses, ecommerce brands and organisations' },
  },
];
---

<BaseLayout
  title="Web Design Agency Manchester | CNVRT"
  description="Web design and development in Manchester for service businesses, ecommerce brands and organisations that need a clearer, higher-performing digital experience."
  additionalSchema={schema}
>
  <SiteHeader />

  <main id="main" class="service-page">
    <section class="service-hero">
      <div class="service-hero__site-reel" data-site-reel aria-hidden="true">
        <div class="site-reel__column">
          <div class="site-reel__track">
            {[false, true].map((duplicate) => (
              <div class="site-reel__group" aria-hidden={duplicate ? 'true' : undefined}>
                {heroReelPrimary.map((image) => <Image src={image} alt="" widths={[360, 560]} sizes="28vw" loading="lazy" />)}
              </div>
            ))}
          </div>
        </div>
        <div class="site-reel__column site-reel__column--reverse">
          <div class="site-reel__track">
            {[false, true].map((duplicate) => (
              <div class="site-reel__group" aria-hidden={duplicate ? 'true' : undefined}>
                {heroReelSecondary.map((image) => <Image src={image} alt="" widths={[360, 560]} sizes="28vw" loading="lazy" />)}
              </div>
            ))}
          </div>
        </div>
      </div>
      <div class="shell">
        <div class="section-rail section-rail--inverse" data-reveal><span>01</span><span>Web design agency</span><span>Manchester, UK</span></div>
        <div class="service-hero__layout">
          <div>
            <h1 class="hero-title service-hero__title" data-reveal="hero-title">
              <span class="hero-title__line"><span class="hero-title__inner">Web design that</span></span>
              <span class="hero-title__line"><span class="hero-title__inner">makes value clear</span></span>
              <span class="hero-title__line"><span class="hero-title__inner">and drives action.</span></span>
            </h1>
            <div class="service-hero__copy" data-reveal style="--reveal-index: 3">
              <p>CNVRT plans, designs and develops distinctive websites for service businesses, ecommerce brands and organisations with something valuable to communicate.</p>
              <p>Every project connects commercial intent, content, user experience and technology so the finished site has a clear job beyond looking polished.</p>
            </div>
            <div class="service-hero__actions" data-reveal style="--reveal-index: 4">
              <a class="button button--paper" href="/submit-a-project/">Submit a project <span aria-hidden="true">↗</span></a>
              <a class="text-link" href="/contact/">Book a call <span aria-hidden="true">↗</span></a>
            </div>
            <div class="service-hero__meta" data-reveal style="--reveal-index: 5"><span>Projects from £1,000</span><span>Available across the UK</span></div>
          </div>
          <figure class="service-hero__brand-art" data-reveal="clip" style="--reveal-index: 2" aria-label="CNVRT web design, connecting clarity, character and conversion">
            <div class="brand-art__letters" aria-hidden="true">
              <span>C</span><span>N</span><span>V</span><span>R</span><span>T</span>
            </div>
            <div class="brand-art__index" aria-hidden="true"><span>CNVRT / 01</span><span>Web design</span></div>
            <div class="brand-art__principles" aria-hidden="true"><span>Clarity</span><span>Character</span><span>Conversion</span></div>
            <figcaption>
              <span>Digital experiences shaped around real business goals.</span>
              <span>Strategy / design / development</span>
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <section class="work-preview" aria-labelledby="work-preview-title">
      <div class="shell work-preview__heading" data-reveal>
        <p id="work-preview-title">Selected website work</p>
        <p>Service, retail and ecommerce projects shaped around distinct customers and commercial goals.</p>
        <a class="text-link" href="#work-showcase">See the work in context <span aria-hidden="true">↓</span></a>
      </div>
      <div class="work-preview__viewport">
        <div class="work-preview__track">
          {previewWork.map((project, index) => (
            <a class="work-preview__card" href={project.href} data-reveal="clip" style={`--reveal-index: ${index}`} aria-label={`View the ${project.name} case study`}>
              <span class="work-preview__image"><ResponsiveProjectImage src={project.image} portraitSrc={'portraitImage' in project ? project.portraitImage : undefined} alt={project.alt} widths={[520, 820, 1100]} sizes="(max-width: 760px) 82vw, 38vw" /></span>
              <span class="work-preview__meta"><strong>{project.name}</strong><span>{project.scope}</span><span aria-hidden="true">↘</span></span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="service-purpose section-pad">
      <div class="shell">
        <div class="section-rail" data-reveal><span>02</span><span>What the website must do</span><span>Purpose before pages</span></div>
        <div class="service-purpose__intro">
          <div data-reveal style="--reveal-index: 1"><EditorialHeading lines={['Clarity before colour', 'Structure before style', 'Purpose in every page']} /></div>
          <div class="service-purpose__copy" data-reveal style="--reveal-index: 2">
            <p>A website is often expected to explain an offer, establish trust, support discovery and produce an action within the same journey. That requires more than attractive screens.</p>
            <p>The work starts by deciding what the right visitor needs to understand, what evidence they need and which next step is commercially useful.</p>
          </div>
        </div>
        <ol class="service-outcomes">
          {outcomes.map(([number, title, description], index) => <li data-reveal style={`--reveal-index: ${index}`}><span>{number}</span><h3>{title}</h3><p>{description}</p></li>)}
        </ol>
      </div>
    </section>

    <section class="service-capabilities section-pad">
      <div class="shell">
        <div class="section-rail section-rail--inverse" data-reveal><span>03</span><span>Project scope</span><span>Designed around the brief</span></div>
        <div class="section-intro section-intro--editorial" data-reveal style="--reveal-index: 1">
          <EditorialHeading lines={['Everything required', 'to shape, build and', 'launch with confidence']} />
          <p>Not every project needs every discipline at the same depth. Scope is built around the business goal, current assets, internal capability and the complexity of the required experience.</p>
        </div>
        <div class="capability-grid">
          {capabilities.map(([number, title, description], index) => <article data-reveal style={`--reveal-index: ${index}`}><span>{number}</span><h3>{title}</h3><p>{description}</p></article>)}
        </div>
      </div>
    </section>

    <section class="mobile-first-panel" id="mobile-first">
      <div class="shell mobile-first-panel__layout">
        <div class="mobile-first-panel__copy" data-reveal>
          <EditorialHeading lines={['Designed from the', 'smallest screen up', 'without compromise']} />
          <p>Mobile is treated as the starting point for hierarchy, content and interaction. Larger layouts then gain space and expression without changing the logic of the journey.</p>
          <div class="mobile-first-panel__checks"><span>Content priority</span><span>Touch and keyboard access</span><span>Responsive type and imagery</span><span>Real breakpoint review</span></div>
        </div>
        <figure class="mobile-first-panel__visual" data-reveal="clip" style="--reveal-index: 2">
          <Image src={mobileFirst} alt="Responsive website interfaces presented across desktop and mobile screens" widths={[760, 1200, 1600]} sizes="(max-width: 760px) 100vw, 50vw" />
        </figure>
      </div>
    </section>

    <section class="platform-section section-pad">
      <div class="shell">
        <div class="section-rail" data-reveal><span>04</span><span>Platform and build</span><span>Fit before preference</span></div>
        <div class="section-intro section-intro--editorial" data-reveal style="--reveal-index: 1">
          <EditorialHeading lines={['The right platform', 'follows the brief', 'not the other way']} />
          <p>Platform choice should account for how the business sells, publishes, integrates systems and manages the site after launch. CNVRT recommends the simplest credible route that can support the required experience.</p>
        </div>
        <div class="platform-list">
          {platforms.map(([number, title, description, href], index) => <a href={href} data-reveal style={`--reveal-index: ${index}`}><span>{number}</span><h3>{title}<span aria-hidden="true">↗</span></h3><p>{description}</p></a>)}
        </div>
      </div>
    </section>

    <section class="service-process section-pad">
      <div class="shell">
        <div class="section-rail section-rail--inverse" data-reveal><span>05</span><span>Delivery process</span><span>Visible from the start</span></div>
        <div class="section-intro section-intro--editorial" data-reveal style="--reveal-index: 1">
          <EditorialHeading lines={['A visible process', 'keeps decisions clear', 'and delivery moving']} />
          <p>Each stage has a purpose, a practical output and a point for review. This keeps feedback connected to the commercial goal and prevents important decisions being deferred until development.</p>
        </div>
        <ol class="service-process__steps">
          {process.map(([number, title, description], index) => <li data-reveal style={`--reveal-index: ${index}`}><span>{number}</span><h3>{title}</h3><p>{description}</p></li>)}
        </ol>
      </div>
    </section>

    <section class="service-work section-pad" id="work-showcase">
      <div class="shell">
        <div class="section-rail" data-reveal><span>06</span><span>Relevant work</span><span>Service + ecommerce</span></div>
        <div class="section-intro section-intro--editorial" data-reveal style="--reveal-index: 1">
          <EditorialHeading lines={['Different businesses', 'different journeys', 'one considered method']} />
          <p>The visual direction changes with the audience and brief. The underlying method remains focused on clarity, responsive behaviour, useful functionality and the commercial action the site needs to support.</p>
        </div>
        <div class="service-work__grid">
          {work.map((project, index) => (
            <article data-reveal style={`--reveal-index: ${index}`}>
              <div class="service-work__image" data-reveal="clip" style={`--reveal-index: ${index}`}><ResponsiveProjectImage src={project.image} portraitSrc={'portraitImage' in project ? project.portraitImage : undefined} alt={project.alt} widths={[520, 820, 1200]} sizes="(max-width: 760px) 100vw, 60vw" /></div>
              <div class="service-work__meta"><span>{project.number}</span><span>{project.scope}</span></div>
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              <ul class="service-work__proof">{project.proof.map((item) => <li>{item}</li>)}</ul>
              <a class="text-link" href={project.href}>Discuss a similar project <span aria-hidden="true">↗</span></a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="service-investment section-pad">
      <div class="shell">
        <div class="section-rail" data-reveal><span>07</span><span>Investment</span><span>Scope before estimate</span></div>
        <div class="investment-panel" data-reveal>
          <div class="investment-panel__price"><span>Website projects from</span><strong>£1,000</strong></div>
          <div class="investment-panel__body">
            <h3>A useful proposal explains what is being built and why.</h3>
            <p>The starting point covers focused website projects with a clearly defined scope. Final investment reflects the work required rather than a generic page-count package.</p>
            <ul class="investment-panel__factors"><li>Page types and journeys</li><li>Content requirements</li><li>Integrations and data</li><li>Ecommerce or custom functionality</li></ul>
            <div class="investment-panel__actions"><a class="button button--dark" href="/submit-a-project/">Submit a project <span aria-hidden="true">↗</span></a><a class="text-link" href="/contact/">Book a call <span aria-hidden="true">↗</span></a></div>
          </div>
        </div>
      </div>
    </section>

    <section class="service-closing section-pad">
      <div class="shell service-closing__layout">
        <div class="faq-block">
          <div class="section-rail section-rail--inverse" data-reveal><span>08</span><span>Web design questions</span><span>Before starting</span></div>
          <div data-reveal style="--reveal-index: 1"><EditorialHeading lines={['Clear answers before', 'a website project', 'moves into scope']} /></div>
          <div class="faq-list" data-reveal style="--reveal-index: 2">{faqs.map(([question, answer]) => <details><summary>{question}<span aria-hidden="true">+</span></summary><p>{answer}</p></details>)}</div>
        </div>
        <aside class="service-closing__cta" data-reveal>
          <span>Have a project in mind?</span>
          <h3>Start with the goal, the current constraint and what needs to change.</h3>
          <p>A clear brief is useful, but not required. Share what is known and CNVRT can help define the right next step.</p>
          <div><a class="button button--paper" href="/submit-a-project/">Submit a project <span aria-hidden="true">↗</span></a><a class="text-link" href="/contact/">Book a call <span aria-hidden="true">↗</span></a></div>
        </aside>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<script>
  const siteReel = document.querySelector<HTMLElement>('[data-site-reel]');
  const reduceReelMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (siteReel && !reduceReelMotion) {
    const reelObserver = new IntersectionObserver(([entry]) => {
      if (!entry) return;
      siteReel.classList.toggle('is-running', entry.isIntersecting);
    }, { threshold: 0.05 });

    reelObserver.observe(siteReel);
  }
</script>
