---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import EditorialHeading from '@/components/EditorialHeading.astro';
import EditorialImagePlaceholder from '@/components/EditorialImagePlaceholder.astro';
import ResponsiveProjectImage from '@/components/ResponsiveProjectImage.astro';
import { services, type ServicePageData } from '@/data/services';
import '@/styles/growth-service-page.css';
import hearBetter from '@/assets/hear-better-home-test-landscape.png';
import heatons from '@/assets/heatons-outcome-landscape.png';
import heatonsPortrait from '@/assets/heatons-outcome-portrait.png';
import uberKinky from '@/assets/uberkinky.jpg';
import topDraw from '@/assets/topdraw-prize-car-landscape.png';
import topDrawPortrait from '@/assets/topdraw-prize-car-portrait.png';
import rftRecruitment from '@/assets/rft-recruitment-outcome-landscape.png';
import rftRecruitmentPortrait from '@/assets/rft-recruitment-outcome-portrait.png';
import yaOmri from '@/assets/ya-omri-shopify.jpg';
import shopifyPartners from '@/assets/credentials/shopify-partners-white.png';

export function getStaticPaths() {
  return services.map((service) => ({ params: { slug: service.slug }, props: { service } }));
}

interface Props {
  service: ServicePageData;
}

const { service } = Astro.props as Props;
const migrationPlatforms = [
  { name: 'WooCommerce', logo: '/logos/ecommerce-platforms/woocommerce-wordmark.png', width: 2157, height: 729, wide: true, large: true },
  { name: 'Adobe Commerce / Magento', logo: '/logos/ecommerce-platforms/magento-wordmark.png', width: 1983, height: 793, wide: true, large: true },
  { name: 'Wix', logo: '/logos/ecommerce-platforms/wix.svg', width: 24, height: 24 },
  { name: 'Squarespace', logo: '/logos/ecommerce-platforms/squarespace.svg', width: 24, height: 24 },
  { name: 'BigCommerce', logo: '/logos/ecommerce-platforms/bigcommerce-wordmark.png', width: 2172, height: 724, wide: true, large: true },
  { name: 'PrestaShop', logo: '/logos/ecommerce-platforms/prestashop.svg', width: 24, height: 24 },
  { name: 'OpenCart', logo: '/logos/ecommerce-platforms/opencart.webp', width: 750, height: 750, wide: true, large: true },
  { name: 'Shopware', logo: '/logos/ecommerce-platforms/shopware.svg', width: 24, height: 24 },
  { name: 'SHOPLINE', logo: '/logos/ecommerce-platforms/shopline.webp', width: 550, height: 550, wide: true, large: true },
  { name: 'Salesforce Commerce Cloud', logo: '/logos/ecommerce-platforms/salesforce.svg', width: 24, height: 24 },
];
const projectMap = {
  'hear-better': {
    name: 'Hear Better',
    scope: 'Brand, website, SEO, AEO and paid acquisition',
    href: '/work/hear-better/',
    image: hearBetter,
    alt: 'Hear Better website project by CNVRT',
  },
  heatons: {
    name: 'Heatons Furniture',
    scope: 'Shopify, email marketing and Meta Ads',
    href: '/work/heatons-furniture/',
    image: heatons,
    portraitImage: heatonsPortrait,
    alt: 'Representative couple relaxing together on a comfortable corner sofa',
  },
  uberkinky: {
    name: 'UberKinky',
    scope: 'Shopline to Shopify Plus migration and custom theme',
    href: '/work/uberkinky/',
    image: uberKinky,
    alt: 'UberKinky Shopify project by CNVRT',
  },
  topdraw: {
    name: 'TopDraw',
    scope: 'Custom competition, commerce and admin platform',
    href: '/work/topdraw/',
    image: topDraw,
    portraitImage: topDrawPortrait,
    alt: 'Representative blue sports car presented as a competition prize with a satin bow',
  },
  rft: {
    name: 'RFT Recruitment',
    scope: 'Lead-generation website and custom recruitment CRM',
    href: '/work/rft-recruitment/',
    image: rftRecruitment,
    portraitImage: rftRecruitmentPortrait,
    alt: 'Representative professional women greeting one another in a modern Manchester office',
  },
  'ya-omri': {
    name: 'Ya Omri',
    scope: 'Luxury custom Shopify redesign',
    href: '/work/ya-omri/',
    image: yaOmri,
    alt: 'Ya Omri luxury Shopify project by CNVRT',
  },
} as const;
type ProjectKey = keyof typeof projectMap;
const relevantProjectKeys: Record<string, readonly ProjectKey[]> = {
  'ecommerce-web-design': ['heatons', 'uberkinky', 'ya-omri'],
  shopify: ['heatons', 'uberkinky', 'ya-omri'],
  'shopify-migrations': ['uberkinky'],
  'custom-web-development': ['topdraw', 'rft'],
  'meta-ads': ['heatons'],
  'google-ads': ['hear-better'],
  'ecommerce-ppc': ['uberkinky', 'heatons'],
  'email-marketing': ['heatons'],
  'conversion-rate-optimisation': ['heatons', 'hear-better', 'uberkinky', 'ya-omri'],
  'analytics-conversion-tracking': ['heatons', 'hear-better', 'uberkinky'],
  branding: ['heatons', 'hear-better', 'rft', 'topdraw'],
  'website-support-maintenance': ['hear-better', 'heatons', 'uberkinky', 'rft'],
  seo: ['heatons', 'hear-better'],
  'local-seo': ['hear-better'],
  'technical-seo': ['heatons', 'hear-better', 'uberkinky'],
  'ecommerce-seo': ['heatons', 'uberkinky', 'ya-omri'],
  aeo: ['hear-better'],
  'custom-tools': ['rft', 'topdraw'],
};
const project = projectMap[service.proofProject];
const supportingProjects = (relevantProjectKeys[service.slug] ?? [service.proofProject])
  .filter((key) => key !== service.proofProject)
  .map((key) => projectMap[key]);
const serviceImageBriefs: Record<string, [string, string]> = {
  'ecommerce-web-design': ['Customer journey in context', 'Customer browsing a product-led ecommerce experience'],
  shopify: ['Storefront in context', 'Shopify merchandising and storefront working session'],
  'shopify-migrations': ['Migration in context', 'Legacy catalogue mapping and Shopify migration planning'],
  'custom-web-development': ['Platform in context', 'Custom platform interface used in a real customer journey'],
  'meta-ads': ['Campaign in context', 'Paid-social creative review and campaign planning session'],
  'google-ads': ['Search in context', 'Search demand, landing-page and campaign review'],
  'ecommerce-ppc': ['Retail media in context', 'Product feed, Merchant Center and ecommerce campaign review'],
  'email-marketing': ['Retention in context', 'Lifecycle journey, customer data and campaign creative'],
  'conversion-rate-optimisation': ['Improvement in context', 'Customer journey review, evidence and prioritised interface change'],
  'analytics-conversion-tracking': ['Measurement in context', 'Analytics, advertising and customer outcomes reviewed together'],
  branding: ['Identity in context', 'Brand direction, visual system and real commercial applications'],
  'website-support-maintenance': ['Support in context', 'Website backlog, technical care and continuous improvement review'],
  seo: ['Organic growth in context', 'Search strategy and content-planning working session'],
  'local-seo': ['Local search in context', 'Customer journey from local discovery to enquiry'],
  'technical-seo': ['Technical SEO in context', 'Technical audit and implementation review with developers'],
  'ecommerce-seo': ['Catalogue search in context', 'Collection architecture and ecommerce search planning'],
  aeo: ['Answer visibility in context', 'Expert content captured and structured for search and AI'],
  'custom-tools': ['Operations in context', 'Custom internal tool used inside the daily workflow'],
};
const imageBrief = serviceImageBriefs[service.slug] ?? [`${service.navLabel} in context`, `${service.navLabel} work shown inside the customer journey`];
const pageUrl = new URL(`/services/${service.slug}/`, Astro.site).href;
const schema = [
  {
    '@type': 'WebPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: service.title,
    description: service.description,
    isPartOf: { '@id': `${Astro.site}#website` },
    about: { '@id': `${pageUrl}#service` },
    inLanguage: 'en-GB',
  },
  {
    '@type': 'Service',
    '@id': `${pageUrl}#service`,
    name: service.serviceType,
    serviceType: service.serviceType,
    url: pageUrl,
    provider: { '@id': `${Astro.site}#organization` },
    areaServed: { '@type': 'Country', name: 'United Kingdom' },
    audience: { '@type': 'BusinessAudience', audienceType: service.audience },
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${pageUrl}#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site },
      { '@type': 'ListItem', position: 2, name: 'Services', item: new URL('/#services', Astro.site).href },
      { '@type': 'ListItem', position: 3, name: service.navLabel, item: pageUrl },
    ],
  },
];
---

<BaseLayout title={service.title} description={service.description} additionalSchema={schema}>
  <SiteHeader />

  <main id="main" class="growth-service" data-service={service.slug}>
    <section class="growth-service__hero">
      <div class="growth-service__hero-grid" aria-hidden="true"></div>
      <div class="shell">
        <div class="section-rail section-rail--inverse" data-reveal>
          <span>01</span><span>{service.eyebrow}</span><span>{service.location}</span>
        </div>
        <div class="growth-service__hero-layout">
          <div class="growth-service__hero-copy">
            <h1 class="hero-title growth-service__title" data-reveal="hero-title">
              {service.hero.map((line) => <span class="hero-title__line"><span class="hero-title__inner">{line}</span></span>)}
            </h1>
            <div class="growth-service__intro" data-reveal style="--reveal-index: 3">
              {service.intro.map((paragraph) => <p>{paragraph}</p>)}
            </div>
            {service.slug === 'shopify' && (
              <div class="growth-service__credential" data-reveal style="--reveal-index: 4">
                <Image src={shopifyPartners} alt="Shopify Partners" width={2048} />
                <span>Shopify design, development and migration experts</span>
              </div>
            )}
            <div class="growth-service__actions" data-reveal style="--reveal-index: 4">
              <a class="button button--paper" href="/request-an-audit/">Request an audit <span aria-hidden="true">↗</span></a>
              <a class="text-link" href="/contact/">Book a call <span aria-hidden="true">↗</span></a>
            </div>
          </div>

          <div class="system-visual" data-reveal="clip" style="--reveal-index: 2" aria-label={`${service.navLabel} delivery system`}>
            <div class="system-visual__top"><span>CNVRT / SERVICE</span><span>{service.visualLabel}</span></div>
            <div class="system-visual__canvas" aria-hidden="true">
              <span class="system-visual__orbit system-visual__orbit--one"></span>
              <span class="system-visual__orbit system-visual__orbit--two"></span>
              <span class="system-visual__axis system-visual__axis--x"></span>
              <span class="system-visual__axis system-visual__axis--y"></span>
              <span class="system-visual__node"><b>CNVRT</b><i>{service.navLabel}</i></span>
              {service.visualSignals.map((signal, index) => <span class={`system-visual__signal system-visual__signal--${index + 1}`}>{signal}</span>)}
            </div>
            <div class="system-visual__footer">{service.heroTags.map((tag) => <span>{tag}</span>)}</div>
          </div>
        </div>
      </div>
    </section>

    {service.slug === 'shopify-migrations' && (
      <section class="migration-platforms" aria-labelledby="migration-platforms-title">
        <div class="shell migration-platforms__layout">
          <div class="migration-platforms__intro" data-reveal>
            <span>Common source platforms</span>
            <h2 id="migration-platforms-title">Move from an established ecommerce platform to Shopify.</h2>
            <p>The migration method follows the source system, available exports, catalogue complexity and records the business genuinely needs to retain.</p>
          </div>
          <div class="migration-platforms__marquee" aria-label="Ecommerce platforms that can be assessed for migration to Shopify">
            <div class="migration-platforms__track">
              <ul class="migration-platforms__group">
                {migrationPlatforms.map((platform) => (
                  <li><img class:list={{ 'migration-platforms__logo--wide': platform.wide, 'migration-platforms__logo--large': platform.large }} src={platform.logo} alt={platform.name} width={platform.width} height={platform.height} loading="lazy" decoding="async" /></li>
                ))}
              </ul>
              <ul class="migration-platforms__group" aria-hidden="true">
                {migrationPlatforms.map((platform) => (
                  <li><img class:list={{ 'migration-platforms__logo--wide': platform.wide, 'migration-platforms__logo--large': platform.large }} src={platform.logo} alt="" width={platform.width} height={platform.height} loading="lazy" decoding="async" /></li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>
    )}

    <section class="service-diagnostic section-pad">
      <div class="shell">
        <div class="section-rail" data-reveal><span>02</span><span>The commercial problem</span><span>Clarity before activity</span></div>
        <div class="service-diagnostic__intro">
          <div data-reveal style="--reveal-index: 1"><EditorialHeading lines={service.problemHeading} /></div>
          <div class="service-diagnostic__copy" data-reveal style="--reveal-index: 2">
            {service.problemCopy.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>
        <EditorialImagePlaceholder
          className="service-diagnostic__media"
          label={imageBrief[0]}
          title={imageBrief[1]}
          size="1800 × 1100 px"
          aspect="cinematic"
          tone="warm"
          revealIndex={2}
        />
        <ol class="service-result-grid">
          {service.outcomes.map(([title, description], index) => (
            <li data-reveal style={`--reveal-index: ${index}`}>
              <span>0{index + 1}</span><h3>{title}</h3><p>{description}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="service-scope section-pad">
      <div class="shell">
        <div class="section-rail section-rail--inverse" data-reveal><span>03</span><span>What CNVRT delivers</span><span>Scope follows the brief</span></div>
        <div class="service-scope__intro" data-reveal style="--reveal-index: 1">
          <EditorialHeading lines={service.scopeHeading} />
          <p>{service.scopeCopy}</p>
        </div>
        <div class="service-scope__grid">
          {service.capabilities.map(([title, description], index) => (
            <article data-reveal style={`--reveal-index: ${index}`}>
              <span>0{index + 1}</span>
              <div class="service-scope__mark" aria-hidden="true"><i></i><i></i></div>
              <h3>{title}</h3><p>{description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="service-proof section-pad">
      <div class="shell">
        <div class="section-rail" data-reveal><span>04</span><span>Work in context</span><span>{project.name}</span></div>
        <div class="service-proof__intro" data-reveal style="--reveal-index: 1">
          <EditorialHeading lines={service.proofHeading} />
          <p>{service.proofCopy}</p>
        </div>
        <a class="service-proof__project" href={project.href} data-reveal="clip" style="--reveal-index: 2">
          <span class="service-proof__image"><ResponsiveProjectImage src={project.image} portraitSrc={'portraitImage' in project ? project.portraitImage : undefined} alt={project.alt} widths={[640, 960, 1440, 1920]} sizes="(max-width: 760px) 100vw, 70vw" /></span>
          <span class="service-proof__caption">
            <span><small>Selected project</small><strong>{project.name}</strong></span>
            <span>{project.scope}</span><b aria-hidden="true">↗</b>
          </span>
        </a>
        <ul class="service-proof__points">{service.proofPoints.map((point) => <li>{point}</li>)}</ul>
        {supportingProjects.length > 0 && (
          <div class="service-proof__related" aria-label="More relevant case studies">
            <span>More relevant work</span>
            {supportingProjects.map((relatedProject) => (
              <a href={relatedProject.href}><span><strong>{relatedProject.name}</strong><small>{relatedProject.scope}</small></span><b aria-hidden="true">↗</b></a>
            ))}
          </div>
        )}
      </div>
    </section>

    <section class="service-method section-pad">
      <div class="shell">
        <div class="section-rail section-rail--inverse" data-reveal><span>05</span><span>How the work moves</span><span>Visible decisions</span></div>
        <div class="service-method__intro" data-reveal style="--reveal-index: 1">
          <EditorialHeading lines={service.processHeading} />
          <p>{service.processCopy}</p>
        </div>
        <ol class="service-method__steps">
          {service.process.map(([title, description], index) => (
            <li data-reveal style={`--reveal-index: ${index}`}><span>0{index + 1}</span><h3>{title}</h3><p>{description}</p></li>
          ))}
        </ol>
      </div>
    </section>

    <section class="related-services section-pad">
      <div class="shell">
        <div class="section-rail" data-reveal><span>06</span><span>Connected services</span><span>One commercial system</span></div>
        <div class="related-services__intro" data-reveal style="--reveal-index: 1">
          <EditorialHeading lines={service.relatedHeading ?? ['The next constraint', 'may sit outside', 'this one channel']} />
          <p>{service.relatedCopy ?? 'Related services are connected where they improve the complete customer journey, measurement or ability to act on the work.'}</p>
        </div>
        <div class="related-services__grid">
          {service.related.map(([label, description, href], index) => (
            <a href={href} data-reveal style={`--reveal-index: ${index}`}><span>0{index + 1}</span><h3>{label}</h3><p>{description}</p><b aria-hidden="true">↗</b></a>
          ))}
        </div>
      </div>
    </section>

    <section class="service-questions section-pad">
      <div class="shell service-questions__layout">
        <div>
          <div class="section-rail section-rail--inverse" data-reveal><span>07</span><span>{service.navLabel} questions</span><span>Before starting</span></div>
          <div class="service-questions__heading" data-reveal style="--reveal-index: 1"><EditorialHeading lines={['Useful answers', 'before the work', 'moves into scope']} /></div>
          <div class="faq-list" data-reveal style="--reveal-index: 2">
            {service.faqs.map(([question, answer]) => <details><summary>{question}<span aria-hidden="true">+</span></summary><p>{answer}</p></details>)}
          </div>
        </div>
        <aside class="service-questions__cta" data-reveal style="--reveal-index: 2">
          <span>Start with the current constraint</span>
          <h2>Share what is happening now and what better needs to look like.</h2>
          <p>A complete brief is not required. CNVRT can review the context, ask the useful questions and recommend the most credible next step.</p>
          <div><a class="button button--paper" href="/submit-a-project/">Submit a project <span aria-hidden="true">↗</span></a><a class="text-link" href="/contact/">Book a call <span aria-hidden="true">↗</span></a></div>
        </aside>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
